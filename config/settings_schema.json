[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Promo banner",
    "settings": [
      {
        "type": "checkbox",
        "id": "promo_banner_enabled",
        "label": "Enable promo banner",
        "default": false,
        "info": "Show the promo banner below the header and inside the sidecart."
      },
      {
        "type": "richtext",
        "id": "promo_banner_text",
        "label": "Text",
        "default": "<p>Free shipping on orders over $50</p>",
        "info": "Supports bold, italic, links, and line breaks."
      },
      {
        "type": "url",
        "id": "promo_banner_url",
        "label": "Link",
        "info": "Optional. When set, the banner becomes a clickable link."
      },
      {
        "type": "color",
        "id": "promo_banner_bg",
        "label": "Background color",
        "default": "#E53935"
      },
      {
        "type": "color",
        "id": "promo_banner_text_color",
        "label": "Text color",
        "default": "#FFFFFF"
      },
      {
        "type": "range",
        "id": "promo_banner_font_size",
        "label": "Font size",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "range",
        "id": "promo_banner_font_size_mobile",
        "label": "Font size (mobile)",
        "min": 11,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 14
      },
      {
        "type": "header",
        "content": "Visibility"
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_index",
        "label": "Show on homepage",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_product",
        "label": "Show on product pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_collection",
        "label": "Show on collection pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_page",
        "label": "Show on regular pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_blog",
        "label": "Show on blog and article pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_cart",
        "label": "Show on cart page",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_search",
        "label": "Show on search page",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_404",
        "label": "Show on 404 page",
        "default": false
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "header",
        "content": "t:cart.settings.quick_cart_header"
      },
      {
        "type": "checkbox",
        "id": "enable_quick_cart",
        "label": "t:cart.settings.enable_quick_cart",
        "default": true,
        "info": "t:cart.settings.enable_quick_cart_info"
      },
      {
        "type": "checkbox",
        "id": "show_dynamic_checkout",
        "label": "t:cart.settings.show_dynamic_checkout",
        "default": false,
        "info": "t:cart.settings.show_dynamic_checkout_info"
      }
    ]
  }
]
