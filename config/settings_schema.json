[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "t:general.promo_banner",
    "settings": [
      {
        "type": "checkbox",
        "id": "promo_banner_enabled",
        "label": "t:promo_banner.settings.enabled",
        "default": false,
        "info": "t:promo_banner.settings.enabled_info"
      },
      {
        "type": "text",
        "id": "promo_banner_text",
        "label": "t:promo_banner.settings.text",
        "default": "Free shipping on orders over $50"
      },
      {
        "type": "url",
        "id": "promo_banner_url",
        "label": "t:promo_banner.settings.url",
        "info": "t:promo_banner.settings.url_info"
      },
      {
        "type": "color",
        "id": "promo_banner_bg",
        "label": "t:promo_banner.settings.bg",
        "default": "#E53935"
      },
      {
        "type": "color",
        "id": "promo_banner_text_color",
        "label": "t:promo_banner.settings.text_color",
        "default": "#FFFFFF"
      },
      {
        "type": "header",
        "content": "t:promo_banner.settings.visibility_header"
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_index",
        "label": "t:promo_banner.settings.show_index",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_product",
        "label": "t:promo_banner.settings.show_product",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_collection",
        "label": "t:promo_banner.settings.show_collection",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_page",
        "label": "t:promo_banner.settings.show_page",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_blog",
        "label": "t:promo_banner.settings.show_blog",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_cart",
        "label": "t:promo_banner.settings.show_cart",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_search",
        "label": "t:promo_banner.settings.show_search",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "promo_banner_show_404",
        "label": "t:promo_banner.settings.show_404",
        "default": false
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "header",
        "content": "t:cart.settings.quick_cart_header"
      },
      {
        "type": "checkbox",
        "id": "enable_quick_cart",
        "label": "t:cart.settings.enable_quick_cart",
        "default": true,
        "info": "t:cart.settings.enable_quick_cart_info"
      },
      {
        "type": "checkbox",
        "id": "show_dynamic_checkout",
        "label": "t:cart.settings.show_dynamic_checkout",
        "default": false,
        "info": "t:cart.settings.show_dynamic_checkout_info"
      }
    ]
  }
]
