{%- liquid
  assign bg_color = section.settings.background_color | default: '#FCE9EC'
  assign text_color = section.settings.text_color | default: '#3E2027'
-%}

<section
  class="about-partnerships full-width"
  style="--apr-bg: {{ bg_color }}; --apr-text: {{ text_color }};">
  <div class="about-partnerships__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="about-partnerships__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="about-partnerships__intro rte">
        {{ section.settings.intro }}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="about-partnerships__grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="about-partnerships__card about-partnerships__card--linked"
              {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="about-partnerships__card" {{ block.shopify_attributes }}>
          {%- endif -%}

            <div class="about-partnerships__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag: loading: 'lazy', class: 'about-partnerships__image'
                }}
              {%- endif -%}
            </div>
            {%- if block.settings.heading != blank -%}
              <h3 class="about-partnerships__card-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="about-partnerships__card-text rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.about-partnerships {
  background-color: var(--apr-bg);
  color: var(--apr-text);
  padding: 80px 0;
}

.about-partnerships__container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
}

.about-partnerships__heading {
  font-family: var(--font-alyona);
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 400;
  line-height: 1.1;
  text-align: center;
  margin: 0 0 24px;
  color: var(--apr-text);
}

.about-partnerships__intro {
  font-family: var(--font-jokker);
  font-size: 16px;
  line-height: 1.6;
  text-align: center;
  max-width: 700px;
  margin: 0 auto 60px;
  color: var(--apr-text);
}

.about-partnerships__intro p {
  margin: 0 0 12px;
}

.about-partnerships__intro p:last-child {
  margin-bottom: 0;
}

.about-partnerships__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px 32px;
}

.about-partnerships__card {
  display: block;
  color: inherit;
  text-decoration: none;
}

.about-partnerships__card--linked {
  transition: opacity 0.2s ease;
}

.about-partnerships__card--linked:hover {
  opacity: 0.85;
}

.about-partnerships__card--linked:focus-visible {
  outline: 2px solid var(--apr-text);
  outline-offset: 4px;
}

.about-partnerships__image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  margin-bottom: 20px;
  background-color: color-mix(in srgb, var(--apr-text) 8%, var(--apr-bg));
}

.about-partnerships__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.about-partnerships__card-heading {
  font-family: var(--font-alyona);
  font-size: 24px;
  font-weight: 400;
  line-height: 1.2;
  margin: 0 0 12px;
  color: var(--apr-text);
}

.about-partnerships__card-text {
  font-family: var(--font-jokker);
  font-size: 14px;
  line-height: 1.6;
  color: var(--apr-text);
}

.about-partnerships__card-text p {
  margin: 0 0 10px;
}

.about-partnerships__card-text p:last-child {
  margin-bottom: 0;
}

@media (min-width: 769px) {
  .about-partnerships {
    padding: 120px 0;
  }

  .about-partnerships__grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 56px 40px;
  }

  .about-partnerships__card-heading {
    font-size: 28px;
  }

  .about-partnerships__card-text {
    font-size: 15px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_partnerships.name",
  "tag": "section",
  "class": "about-partnerships-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.about_partnerships.settings.content_header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.about_partnerships.settings.intro"
    },
    {
      "type": "header",
      "content": "t:sections.about_partnerships.settings.colors_header"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#FCE9EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#3E2027"
    }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "t:sections.about_partnerships.blocks.partner.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.about_partnerships.blocks.partner.text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.about_partnerships.blocks.partner.link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.about_partnerships.name",
      "blocks": [
        { "type": "partner" },
        { "type": "partner" },
        { "type": "partner" }
      ]
    }
  ]
}
{% endschema %}
