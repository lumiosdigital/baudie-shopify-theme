{%- comment -%}
  How to Use section — usage steps, dosage guide, and media (image/video).
{%- endcomment -%}

{%- liquid
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign dosage_blocks = section.blocks | where: 'type', 'dosage'
-%}

<section
  class="how-to-use full-width"
  data-section-id="{{ section.id }}"
  aria-label="{{ section.settings.title | default: 'How to use' }}"
  style="--section-bg: {{ section.settings.background_color }}; --text-color: {{ section.settings.text_color }};">

  <div class="how-to-use__inner">
  <div class="how-to-use__content">
    {% if section.settings.title != blank %}
      <h2 class="how-to-use__title">{{ section.settings.title }}</h2>
    {% endif %}

    {%- comment -%} Step Icons {%- endcomment -%}
    {% if step_blocks.size > 0 %}
      <div class="how-to-use__steps">
        {% for block in step_blocks %}
          <div class="how-to-use__step" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <div class="how-to-use__step-icon">
                {{ block.settings.icon | image_url: width: 120 | image_tag:
                  loading: 'lazy',
                  class: 'how-to-use__step-img',
                  alt: block.settings.label | default: ''
                }}
              </div>
            {% endif %}
            {% if block.settings.label != blank %}
              <p class="how-to-use__step-label">{{ block.settings.label }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} Description (hidden on mobile) {%- endcomment -%}
    {% if section.settings.description != blank %}
      <div class="how-to-use__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {%- comment -%} Sprays Title + Dosage List {%- endcomment -%}
    {% if section.settings.sprays_title != blank %}
      <h3 class="how-to-use__sprays-title">{{ section.settings.sprays_title }}</h3>
    {% endif %}

    {% if dosage_blocks.size > 0 %}
      <div class="how-to-use__dosage-list">
        {% for block in dosage_blocks %}
          <div class="how-to-use__dosage-row" {{ block.shopify_attributes }}>
            <p class="how-to-use__dosage-label">{{ block.settings.label }}</p>
            <div class="how-to-use__dosage-info">
              <div class="how-to-use__dosage-drops" aria-hidden="true">
                {% for i in (1..block.settings.drops) %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M12 22c-4.97 0-9-3.58-9-8 0-4.42 4-9 9-14 5 5 9 9.58 9 14 0 4.42-4.03 8-9 8z"/>
                  </svg>
                {% endfor %}
              </div>
              <p class="how-to-use__dosage-amount">{{ block.settings.amount }}</p>
            </div>
          </div>
          <hr class="how-to-use__dosage-divider">
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {%- comment -%} Media Column (image or video) — product metafield takes priority over section settings {%- endcomment -%}
  <div class="how-to-use__media">
    {%- liquid
      assign meta_video = product.metafields.custom.how_to_use_video.value
      assign meta_image = product.metafields.custom.how_to_use_image.value
    -%}
    {% if meta_video != blank %}
      <video
        class="how-to-use__video"
        autoplay
        loop
        muted
        playsinline
        src="{{ meta_video.sources[1].url | default: meta_video.sources[0].url }}">
      </video>
    {% elsif meta_image != blank %}
      {{ meta_image | image_url: width: 1440 | image_tag:
        loading: 'lazy',
        class: 'how-to-use__image',
        alt: product.title | append: ' - ' | append: section.settings.title | default: 'How to use'
      }}
    {% elsif section.settings.media_video != blank %}
      {{ section.settings.media_video | video_tag:
        class: 'how-to-use__video',
        autoplay: true,
        loop: true,
        muted: true,
        playsinline: true,
        controls: false
      }}
    {% elsif section.settings.media_image %}
      {{ section.settings.media_image | image_url: width: 1440 | image_tag:
        loading: 'lazy',
        class: 'how-to-use__image',
        alt: section.settings.title | default: 'How to use'
      }}
    {% endif %}
  </div>
  </div>
</section>

{% stylesheet %}
  .how-to-use {
    background-color: var(--section-bg, #FFF7EA);
  }

  .how-to-use__inner {
    display: flex;
    flex-direction: column;
  }

  /* --- Content Column --- */

  .how-to-use__content {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding: 54px 12px 40px;
    overflow: hidden;
  }

  /* --- Title --- */

  .how-to-use__title {
    font-family: var(--font-alyona);
    font-weight: 400;
    font-size: 34px;
    line-height: 1;
    color: var(--text-color, #3E2027);
    margin: 0;
  }

  /* --- Steps --- */

  .how-to-use__steps {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .how-to-use__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    width: 90px;
  }

  .how-to-use__step-icon {
    width: 60px;
    height: 60px;
    overflow: hidden;
  }

  .how-to-use__step-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .how-to-use__step-label {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    line-height: normal;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    text-align: center;
    color: var(--text-color, #3E2027);
    margin: 0;
  }

  /* --- Description (hidden on mobile) --- */

  .how-to-use__description {
    display: none;
    font-family: var(--font-jokker);
    font-size: 18px;
    line-height: 1.5;
    color: var(--text-color, #3E2027);
  }

  .how-to-use__description p {
    margin: 0;
  }

  /* --- Sprays Title --- */

  .how-to-use__sprays-title {
    font-family: var(--font-alyona);
    font-weight: 400;
    font-size: 34px;
    line-height: 1;
    color: var(--text-color, #3E2027);
    margin: 0;
  }

  /* --- Dosage List --- */

  .how-to-use__dosage-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .how-to-use__dosage-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .how-to-use__dosage-label {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    line-height: normal;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    color: var(--text-color, #3E2027);
    margin: 0;
  }

  .how-to-use__dosage-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .how-to-use__dosage-drops {
    display: flex;
    align-items: center;
  }

  .how-to-use__dosage-drops svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .how-to-use__dosage-amount {
    font-family: var(--font-sweet-sans);
    font-weight: 400;
    font-size: 14px;
    line-height: normal;
    letter-spacing: -0.14px;
    color: var(--text-color, #3E2027);
    margin: 0;
    white-space: nowrap;
  }

  .how-to-use__dosage-divider {
    width: 100%;
    height: 0;
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--text-color, #3E2027) 20%, transparent);
    margin: 0;
  }

  /* --- Media Column --- */

  .how-to-use__media {
    position: relative;
    width: 100%;
    min-height: 0;
    flex: 1;
    overflow: hidden;
  }

  .how-to-use__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-to-use__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ============================================
     Desktop (1024px+)
     ============================================ */

  @media (min-width: 1024px) {
    .how-to-use__inner {
      flex-direction: row;
    }

    .how-to-use__content {
      width: 50%;
      padding: 160px 40px 80px;
      gap: 40px;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100svh;
      align-self: flex-start;
      overflow-y: auto;
      justify-content: center;
    }

    .how-to-use__title {
      font-size: 70px;
    }

    .how-to-use__steps {
      justify-content: flex-start;
      gap: 70px;
    }

    .how-to-use__step {
      width: auto;
    }

    .how-to-use__step-label {
      font-size: 18px;
      letter-spacing: -0.18px;
      white-space: nowrap;
    }

    .how-to-use__description {
      display: block;
    }

    .how-to-use__sprays-title {
      font-size: 40px;
    }

    .how-to-use__dosage-label {
      font-size: 18px;
      letter-spacing: -0.18px;
    }

    .how-to-use__dosage-amount {
      font-size: 16px;
      letter-spacing: -0.16px;
    }

    .how-to-use__media {
      width: 50%;
      flex: 0 0 50%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.how_to_use.name",
  "class": "how-to-use-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.how_to_use.title",
      "default": "How to use"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.how_to_use.description",
      "default": "<p>Baudie is the first pre-deodorant spray powered by odor-eliminating bacterial technology. It targets the real cause of body odor — the bacteria that make sweat smell — using gentle AHAs to create a slightly acidic environment where they can't survive. The wipe-off formula cleanses and resets your skin, while plant-powered actives support a balanced microbiome. The result is science-backed freshness that lasts longer and makes your deodorant work better.</p>"
    },
    {
      "type": "text",
      "id": "sprays_title",
      "label": "t:sections.how_to_use.sprays_title",
      "default": "How many sprays do i need?"
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "t:sections.how_to_use.media_image"
    },
    {
      "type": "video",
      "id": "media_video",
      "label": "t:sections.how_to_use.media_video"
    },
    {
      "type": "header",
      "content": "t:labels.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#FFF7EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#3E2027"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.how_to_use.step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:sections.how_to_use.step_icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.how_to_use.step_label"
        }
      ]
    },
    {
      "type": "dosage",
      "name": "t:sections.how_to_use.dosage",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.how_to_use.dosage_label"
        },
        {
          "type": "range",
          "id": "drops",
          "label": "t:sections.how_to_use.dosage_drops",
          "min": 1,
          "max": 12,
          "step": 1,
          "default": 2
        },
        {
          "type": "text",
          "id": "amount",
          "label": "t:sections.how_to_use.dosage_amount"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to use",
      "blocks": [
        { "type": "step", "settings": { "label": "Spray" } },
        { "type": "step", "settings": { "label": "Wipe" } },
        { "type": "step", "settings": { "label": "Apply Deo" } },
        { "type": "step", "settings": { "label": "Stay fresh" } },
        { "type": "dosage", "settings": { "label": "I smell a little", "drops": 2, "amount": "2-4 Sprays" } },
        { "type": "dosage", "settings": { "label": "It's... Noticeable", "drops": 4, "amount": "4-8 Sprays" } },
        { "type": "dosage", "settings": { "label": "I'm really stinky", "drops": 8, "amount": "8–12 Sprays" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
