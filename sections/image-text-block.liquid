{%- liquid
  assign bg_color = section.settings.background_color | default: '#FFF7EA'
  assign text_color = section.settings.text_color | default: '#3E2027'
  assign image_position = section.settings.image_position | default: 'left'
  assign image_ratio = section.settings.image_aspect_ratio | default: 'portrait'
  assign container_width = section.settings.container_width | default: 'standard'
-%}

<section
  class="image-text-block image-text-block--image-{{ image_position }} image-text-block--ratio-{{ image_ratio }} image-text-block--{{ container_width }} full-width"
  style="--itb-bg: {{ bg_color }}; --itb-text: {{ text_color }};">
  <div class="image-text-block__container">
    <div class="image-text-block__grid">
      <div class="image-text-block__image-col">
        {%- if section.settings.image != blank -%}
          <div class="image-text-block__image-wrapper">
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag: loading: 'lazy', class: 'image-text-block__image'
            }}
          </div>
        {%- else -%}
          <div class="image-text-block__image-wrapper image-text-block__image-wrapper--placeholder"></div>
        {%- endif -%}
      </div>
      <div class="image-text-block__text-col">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-text-block__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="image-text-block__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="image-text-block__body rte">
            {{ section.settings.body }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.image-text-block {
  color: var(--itb-text);
  padding: 80px 0;
}

.image-text-block__text-col {
  background-color: var(--itb-bg);
  padding: 40px 28px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.image-text-block--full {
  background-color: var(--itb-bg);
}

.image-text-block--full .image-text-block__text-col {
  background-color: transparent;
  padding: 0;
}

.image-text-block__container {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 40px;
}

.image-text-block--wide .image-text-block__container {
  max-width: 1800px;
}

.image-text-block--full {
  padding: 0;
  margin: 40px 0;
}

.image-text-block--full .image-text-block__container {
  max-width: none;
  padding: 0;
}

.image-text-block__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  align-items: stretch;
}

.image-text-block__image-col {
  display: flex;
}

.image-text-block__image-wrapper {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background-color: color-mix(in srgb, var(--itb-text) 8%, var(--itb-bg));
  min-height: 360px;
}

.image-text-block--ratio-square .image-text-block__image-wrapper {
  aspect-ratio: 1 / 1;
}

.image-text-block--ratio-portrait .image-text-block__image-wrapper {
  aspect-ratio: 4 / 5;
}

.image-text-block--ratio-landscape .image-text-block__image-wrapper {
  aspect-ratio: 4 / 3;
}

.image-text-block__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.image-text-block__eyebrow {
  font-family: var(--font-jokker);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  margin: 0 0 16px;
  color: var(--itb-text);
}

.image-text-block__heading {
  font-family: var(--font-alyona);
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 400;
  line-height: 1.1;
  margin: 0 0 24px;
  color: var(--itb-text);
}

.image-text-block__body {
  font-family: var(--font-jokker);
  font-size: 16px;
  line-height: 1.6;
  color: var(--itb-text);
}

.image-text-block__body p {
  margin: 0 0 16px;
}

.image-text-block__body p:last-child {
  margin-bottom: 0;
}

.image-text-block__body a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

@media (min-width: 769px) {
  .image-text-block {
    padding: 120px 0;
  }

  .image-text-block__text-col {
    padding: 64px 56px;
  }

  .image-text-block__grid {
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .image-text-block--image-right .image-text-block__image-col {
    order: 2;
  }

  .image-text-block--image-right .image-text-block__text-col {
    order: 1;
  }

  .image-text-block__body {
    font-size: 17px;
  }

  .image-text-block--full {
    padding: 0;
  }

  .image-text-block--full .image-text-block__grid {
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
  }

  .image-text-block--full .image-text-block__image-col {
    display: flex;
  }

  .image-text-block--full .image-text-block__image-wrapper {
    aspect-ratio: auto;
    height: 100%;
    min-height: 520px;
  }

  .image-text-block--full .image-text-block__text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px clamp(48px, 6vw, 120px);
  }

  .image-text-block--full .image-text-block__text-col > * {
    max-width: 720px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.image_text_block.name",
  "tag": "section",
  "class": "image-text-block-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.image_text_block.settings.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.image_text_block.settings.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.image_text_block.settings.body"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "header",
      "content": "t:sections.image_text_block.settings.layout_header"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.image_text_block.settings.image_position",
      "options": [
        { "value": "left", "label": "t:sections.image_text_block.settings.image_left" },
        { "value": "right", "label": "t:sections.image_text_block.settings.image_right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "t:sections.image_text_block.settings.image_aspect_ratio",
      "options": [
        { "value": "square", "label": "t:sections.image_text_block.settings.ratio_square" },
        { "value": "portrait", "label": "t:sections.image_text_block.settings.ratio_portrait" },
        { "value": "landscape", "label": "t:sections.image_text_block.settings.ratio_landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.image_text_block.settings.container_width",
      "options": [
        { "value": "standard", "label": "t:sections.image_text_block.settings.width_standard" },
        { "value": "wide", "label": "t:sections.image_text_block.settings.width_wide" },
        { "value": "full", "label": "t:sections.image_text_block.settings.width_full" }
      ],
      "default": "standard",
      "info": "t:sections.image_text_block.settings.container_width_info"
    },
    {
      "type": "header",
      "content": "t:sections.image_text_block.settings.colors_header"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#FFF7EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#3E2027"
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_text_block.name"
    }
  ]
}
{% endschema %}
