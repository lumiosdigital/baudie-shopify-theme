{%- liquid
  assign background_color = section.settings.background_color | default: '#FFFFFF'
  assign text_color = section.settings.text_color | default: '#3E2027'
  assign button_bg = section.settings.button_background_color | default: '#3E2027'
  assign button_text_color = section.settings.button_text_color | default: '#FFFFFF'
  assign input_border = section.settings.input_border_color | default: '#3E2027'
-%}

<section
  class="password-page full-width"
  style="
    --pp-bg-color: {{ background_color }};
    --pp-text: {{ text_color }};
    --pp-button-bg: {{ button_bg }};
    --pp-button-text: {{ button_text_color }};
    --pp-input-border: {{ input_border }};
  ">
  <div class="password-page__content">
    {%- if section.settings.logo != blank -%}
      {{
        section.settings.logo
        | image_url: width: 800
        | image_tag: loading: 'eager', alt: shop.name, class: 'password-page__logo'
      }}
    {%- endif -%}

    <div class="password-page__action">
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <div class="password-page__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <label class="visually-hidden" for="password-input">
          {{ section.settings.password_placeholder }}
        </label>
        <input
          type="password"
          name="password"
          id="password-input"
          class="password-page__input"
          placeholder="{{ section.settings.password_placeholder }}"
          aria-label="{{ section.settings.password_placeholder }}"
          autocomplete="current-password"
          required>

        <button type="submit" class="password-page__button">
          {{ section.settings.button_text }}
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
.password-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  min-height: 100dvh;
  flex: 1 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  background-color: var(--pp-bg-color);
  color: var(--pp-text);
  overflow: hidden;
}

.password-page__content {
  position: relative;
  z-index: 1;
  max-width: 720px;
  width: 100%;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
}

.password-page__logo {
  display: block;
  height: auto;
  width: auto;
  max-width: 320px;
  margin: 0;
}

.password-page__action {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  width: 100%;
  max-width: 360px;
}

.password-page__action form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  width: 100%;
}

.password-page__errors {
  font-family: var(--font-jokker);
  font-size: 14px;
  color: #B3261E;
  text-align: center;
}

.password-page__errors ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.password-page__input {
  width: 100%;
  height: 50px;
  padding: 12px 16px;
  font-family: var(--font-jokker);
  font-size: 16px;
  color: var(--pp-text);
  background-color: transparent;
  border: 1px solid var(--pp-input-border);
  border-radius: 0;
  outline: none;
  text-align: center;
}

.password-page__input::placeholder {
  color: var(--pp-text);
  opacity: 0.6;
}

.password-page__input:focus {
  border-color: var(--pp-text);
  box-shadow: 0 0 0 1px var(--pp-text);
}

.password-page__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50px;
  padding: 10px 40px;
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 14px;
  line-height: normal;
  letter-spacing: -0.14px;
  text-transform: uppercase;
  color: var(--pp-button-text);
  background-color: var(--pp-button-bg);
  border: none;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.password-page__button:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.password-page__button:active {
  opacity: 0.8;
  transform: translateY(0);
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

@media (max-width: 768px) {
  .password-page {
    padding: 40px 24px;
  }

  .password-page__content {
    gap: 24px;
    max-width: 100%;
  }

  .password-page__logo {
    max-width: 220px;
  }

  .password-page__action {
    margin-top: 4px;
    max-width: 100%;
  }

  .password-page__input {
    height: 44px;
    font-size: 14px;
  }

  .password-page__button {
    height: 40px;
    padding: 10px 20px;
    font-size: 12px;
    letter-spacing: -0.12px;
    min-width: 180px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Enter"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password input placeholder",
      "default": "Enter password"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3E2027"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background color",
      "default": "#3E2027"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Password input border color",
      "default": "#3E2027"
    }
  ]
}
{% endschema %}
