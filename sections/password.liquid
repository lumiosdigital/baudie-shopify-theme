{%- liquid
  assign mode = section.settings.mode | default: 'password'
  assign text_color = section.settings.text_color | default: '#3E2027'
  assign button_bg = section.settings.button_background_color | default: '#3E2027'
  assign button_text_color = section.settings.button_text_color | default: '#FFFFFF'
  assign input_border = section.settings.input_border_color | default: '#3E2027'
  assign overlay_color = section.settings.overlay_color | default: '#000000'
  assign overlay_opacity = section.settings.overlay_opacity | default: 0
-%}

<section
  class="password-page full-width"
  style="
    --pp-text: {{ text_color }};
    --pp-button-bg: {{ button_bg }};
    --pp-button-text: {{ button_text_color }};
    --pp-input-border: {{ input_border }};
    --pp-overlay-color: {{ overlay_color }};
    --pp-overlay: {{ overlay_opacity | divided_by: 100.0 }};
    {%- if section.settings.background_image != blank -%}
      --pp-bg: url('{{ section.settings.background_image | image_url: width: 2400 }}');
    {%- endif -%}
    {%- if section.settings.background_image_mobile != blank -%}
      --pp-bg-mobile: url('{{ section.settings.background_image_mobile | image_url: width: 1200 }}');
    {%- elsif section.settings.background_image != blank -%}
      --pp-bg-mobile: url('{{ section.settings.background_image | image_url: width: 1200 }}');
    {%- endif -%}
  ">
  <div class="password-page__overlay" aria-hidden="true"></div>

  <div class="password-page__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="password-page__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.logo_top != blank or section.settings.logo_bottom != blank -%}
      <div class="password-page__logos">
        {%- if section.settings.logo_top != blank -%}
          {{
            section.settings.logo_top
            | image_url: width: 600
            | image_tag: loading: 'eager', alt: shop.name, class: 'password-page__logo password-page__logo--top'
          }}
        {%- endif -%}

        {%- if section.settings.logo_top != blank and section.settings.logo_bottom != blank -%}
          <svg class="password-page__arrow" xmlns="http://www.w3.org/2000/svg" width="11" height="39" viewBox="0 0 11 39" fill="none" aria-hidden="true">
            <path opacity="0.6" d="M4.62886 37.9335C4.90041 38.2051 5.34068 38.2051 5.61223 37.9335L10.0374 33.5084C10.309 33.2368 10.309 32.7965 10.0374 32.525C9.76585 32.2534 9.32558 32.2534 9.05403 32.525L5.12054 36.4585L1.18706 32.525C0.915507 32.2534 0.475237 32.2534 0.203686 32.525C-0.0678644 32.7965 -0.0678644 33.2368 0.203686 33.5084L4.62886 37.9335ZM5.12054 0L4.4252 -3.03947e-08L4.42519 37.4418L5.12054 37.4418L5.81589 37.4418L5.81589 3.03947e-08L5.12054 0Z" fill="currentColor"/>
          </svg>
        {%- endif -%}

        {%- if section.settings.logo_bottom != blank -%}
          {{
            section.settings.logo_bottom
            | image_url: width: 600
            | image_tag: loading: 'eager', alt: shop.name, class: 'password-page__logo password-page__logo--bottom'
          }}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="password-page__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    <div class="password-page__action">
      {%- if mode == 'link' -%}
        <a href="{{ section.settings.button_url | default: '/' }}" class="password-page__button">
          {{ section.settings.button_text }}
        </a>
      {%- else -%}
        {%- form 'storefront_password' -%}
          {%- if form.errors -%}
            <div class="password-page__errors" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <label class="visually-hidden" for="password-input">
            {{ section.settings.password_placeholder }}
          </label>
          <input
            type="password"
            name="password"
            id="password-input"
            class="password-page__input"
            placeholder="{{ section.settings.password_placeholder }}"
            aria-label="{{ section.settings.password_placeholder }}"
            autocomplete="current-password"
            required>

          <button type="submit" class="password-page__button">
            {{ section.settings.button_text }}
          </button>
        {%- endform -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.password-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  min-height: 100dvh;
  flex: 1 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  background-color: #FFFFFF;
  background-image: var(--pp-bg, var(--pp-bg-mobile, none));
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: var(--pp-text);
  overflow: hidden;
}

.password-page__overlay {
  position: absolute;
  inset: 0;
  background-color: var(--pp-overlay-color);
  opacity: var(--pp-overlay);
  pointer-events: none;
}

.password-page__content {
  position: relative;
  z-index: 1;
  max-width: 720px;
  width: 100%;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.password-page__heading {
  font-family: var(--font-alyona);
  font-size: 60px;
  font-weight: 400;
  line-height: 1;
  margin: 0;
  color: var(--pp-text);
}

.password-page__logos {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  margin: 0;
  color: var(--pp-text);
}

.password-page__logo {
  display: block;
  height: auto;
  width: auto;
}

.password-page__logo--top {
  max-width: 266px;
}

.password-page__logo--bottom {
  max-width: 136px;
}

.password-page__arrow {
  display: block;
  width: 11px;
  height: 39px;
  color: var(--pp-text);
}

.password-page__subheading {
  font-family: var(--font-jokker);
  font-size: 20px;
  line-height: 1.5;
  color: var(--pp-text);
  max-width: 520px;
  margin: 0;
}

.password-page__subheading > * {
  margin: 0;
}

.password-page__subheading > * + * {
  margin-top: 8px;
}

.password-page__action {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  width: 100%;
  max-width: 360px;
}

.password-page__action form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  width: 100%;
}

.password-page__errors {
  font-family: var(--font-jokker);
  font-size: 14px;
  color: #B3261E;
  text-align: center;
}

.password-page__errors ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.password-page__input {
  width: 100%;
  height: 50px;
  padding: 12px 16px;
  font-family: var(--font-jokker);
  font-size: 16px;
  color: var(--pp-text);
  background-color: transparent;
  border: 1px solid var(--pp-input-border);
  border-radius: 0;
  outline: none;
  text-align: center;
}

.password-page__input::placeholder {
  color: var(--pp-text);
  opacity: 0.6;
}

.password-page__input:focus {
  border-color: var(--pp-text);
  box-shadow: 0 0 0 1px var(--pp-text);
}

.password-page__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50px;
  padding: 10px 40px;
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 14px;
  line-height: normal;
  letter-spacing: -0.14px;
  text-transform: uppercase;
  color: var(--pp-button-text);
  background-color: var(--pp-button-bg);
  border: none;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.password-page__button:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.password-page__button:active {
  opacity: 0.8;
  transform: translateY(0);
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

@media (max-width: 768px) {
  .password-page {
    padding: 40px 24px;
    background-image: var(--pp-bg-mobile, var(--pp-bg, none));
  }

  .password-page__content {
    gap: 20px;
    max-width: 100%;
  }

  .password-page__heading {
    font-size: 52px;
    max-width: 409px;
  }

  .password-page__logos {
    gap: 12px;
  }

  .password-page__logo--top {
    max-width: 188px;
  }

  .password-page__logo--bottom {
    max-width: 96px;
  }

  .password-page__arrow {
    width: 9px;
    height: 32px;
  }

  .password-page__subheading {
    font-size: 14px;
    max-width: 322px;
  }

  .password-page__action {
    margin-top: 4px;
    max-width: 100%;
  }

  .password-page__input {
    height: 44px;
    font-size: 14px;
  }

  .password-page__button {
    height: 40px;
    padding: 10px 20px;
    font-size: 12px;
    letter-spacing: -0.12px;
    min-width: 180px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": [
    {
      "type": "header",
      "content": "Mode"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Button behavior",
      "options": [
        { "value": "password", "label": "Password form (unlock site)" },
        { "value": "link", "label": "Link (redirect to URL)" }
      ],
      "default": "password",
      "info": "Use 'Link' on Bella Skin Beauty to redirect to baudie.com. Use 'Password form' to gate Baudie.com during preview."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo_top",
      "label": "Top logo (e.g. Bella Skin Beauty)",
      "info": "When both logos are set, an arrow appears between them"
    },
    {
      "type": "image_picker",
      "id": "logo_bottom",
      "label": "Bottom logo (e.g. Baudie)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We've evolved. Meet Baudie."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Same formula you love, now with a new name, new look, and an even better experience.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VISIT BAUDIE.COM"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL (used in Link mode)"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password input placeholder (used in Password mode)",
      "default": "Enter password"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Falls back to desktop image if empty"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3E2027"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background color",
      "default": "#3E2027"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Password input border color",
      "default": "#3E2027"
    }
  ]
}
{% endschema %}
