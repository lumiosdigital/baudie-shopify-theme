{%- comment -%}
  Bundle product page — fully custom build-your-own-bundle.
  Customers pick scents from a collection, images update dynamically,
  and selected items are added to cart individually with a bundle note.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant | default: product.variants.first
  assign product_text_color = product.metafields.custom.product_text_color | default: '#3E2027'
  assign popup_text_color = section.settings.popup_text_color | default: '#3E2027'
  assign gradient_1 = section.settings.gradient_color_1 | default: '#F4D2A4'
  assign gradient_2 = section.settings.gradient_color_2 | default: '#FCF5DE'
  assign bottle_size = product.metafields.custom.bottle_size
  assign product_details = product.metafields.custom.product_details
  assign scent_notes = product.metafields.custom.scent_notes
  assign key_ingredients = product.metafields.custom.key_ingredients
  assign full_ingredient_list = product.metafields.custom.full_ingredient_list
  assign scent_collection = section.settings.scent_collection
  assign bundle_size = section.settings.bundle_size | default: 3
-%}

<section
  class="bundle-main full-width"
  data-section-id="{{ section.id }}"
  data-bundle-size="{{ bundle_size }}"
  aria-label="{{ product.title }}"
  style="--gradient-1: {{ gradient_1 }}; --gradient-2: {{ gradient_2 }}; --product-text: {{ product_text_color }}; --popup-text: {{ popup_text_color }};">

  {%- comment -%} Mobile Header {%- endcomment -%}
  <div class="bundle-main__mobile-header">
    <div class="bundle-main__mobile-subtitle-row">
      <p class="bundle-main__subtitle">{{ product.type | default: 'Deodorant Enhancer®' }}</p>
      {% if bottle_size %}
        <p class="bundle-main__size">{{ bottle_size }}</p>
      {% endif %}
    </div>
    <h1 class="bundle-main__title" data-bundle-title>{{ product.title }}</h1>
  </div>

  {%- comment -%} Image Column — bottle slots {%- endcomment -%}
  <div class="bundle-main__image-column">
    <div class="bundle-main__bottles" data-bundle-bottles>
      {% for i in (1..bundle_size) %}
        <div class="bundle-main__bottle-slot" data-bottle-slot="{{ i }}">
          <img
            class="bundle-main__bottle-img"
            src=""
            alt=""
            loading="{% if i == 1 %}eager{% else %}lazy{% endif %}"
            style="display: none;">
          <div class="bundle-main__bottle-placeholder">
            <span class="bundle-main__bottle-number">{{ i }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  {%- comment -%} Info Column {%- endcomment -%}
  <div class="bundle-main__info-column">

    {%- comment -%} Desktop Header {%- endcomment -%}
    <div class="bundle-main__desktop-header">
      <p class="bundle-main__subtitle">{{ product.type | default: 'Deodorant Enhancer®' }}</p>
      <h1 class="bundle-main__title">{{ product.title }}</h1>
      {% if bottle_size %}
        <p class="bundle-main__size-line">{{ bundle_size }} x {{ bottle_size }}</p>
      {% endif %}
    </div>

    {%- comment -%} Scent Selectors {%- endcomment -%}
    <div class="bundle-main__selectors" data-bundle-selectors>
      {% for i in (1..bundle_size) %}
        <div class="bundle-main__selector" data-scent-selector="{{ i }}">
          <button
            type="button"
            class="bundle-main__selector-trigger"
            aria-expanded="false"
            aria-haspopup="listbox"
            aria-controls="scent-list-{{ i }}-{{ section.id }}">
            <span class="bundle-main__selector-label" data-selector-label>{{ i }}. {{ 'sections.product_bundle.choose_scent' | t }}</span>
            <svg class="bundle-main__selector-chevron" xmlns="http://www.w3.org/2000/svg" width="12" height="6" viewBox="0 0 12 6" fill="none" aria-hidden="true" focusable="false">
              <path d="M1 0.5L6 5.5L11 0.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <ul
            class="bundle-main__selector-list"
            id="scent-list-{{ i }}-{{ section.id }}"
            role="listbox"
            aria-label="{{ i }}. {{ 'sections.product_bundle.choose_scent' | t }}">
            {% if scent_collection %}
              {% for scent_product in scent_collection.products %}
                <li
                  role="option"
                  aria-selected="false"
                  class="bundle-main__selector-option"
                  data-product-handle="{{ scent_product.handle }}"
                  data-product-title="{{ scent_product.title | escape }}"
                  data-variant-id="{{ scent_product.selected_or_first_available_variant.id }}"
                  data-variant-gid="{{ scent_product.selected_or_first_available_variant.id | prepend: 'gid://shopify/ProductVariant/' }}"
                  data-card-image="{% if scent_product.metafields.custom.card_image != blank %}{{ scent_product.metafields.custom.card_image | image_url: width: 800 }}{% elsif scent_product.featured_image %}{{ scent_product.featured_image | image_url: width: 800 }}{% endif %}">
                  {{ scent_product.title }}
                </li>
              {% endfor %}
            {% endif %}
          </ul>
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Divider {%- endcomment -%}
    <hr class="bundle-main__divider">

    {%- comment -%} Price + Actions {%- endcomment -%}
    <div class="bundle-main__purchase-row">
      <p class="bundle-main__price" data-bundle-price>{{ current_variant.price | money }}</p>
      <div class="bundle-main__actions">
        <button
          type="button"
          class="bundle-main__button bundle-main__button--add"
          disabled
          data-bundle-add>
          <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M0.75 7.75H14.75M7.75 0.75V14.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{{ 'sections.product_bundle.add_to_cart' | t }}</span>
        </button>
        <button
          type="button"
          class="bundle-main__button bundle-main__button--buy"
          disabled
          data-bundle-buy>
          {{ 'sections.product_bundle.buy_now' | t }}
        </button>
      </div>
    </div>

    {%- comment -%} Watch It In Action {%- endcomment -%}
    <div class="bundle-main__video-section">
      <p class="bundle-main__video-heading">{{ 'sections.product_bundle.watch_in_action' | t }}</p>
      <div class="bundle-main__video-grid" data-tolstoy-container>
        <div class="bundle-main__video-placeholder"></div>
        <div class="bundle-main__video-placeholder"></div>
        <div class="bundle-main__video-placeholder"></div>
        <div class="bundle-main__video-placeholder"></div>
        <div class="bundle-main__video-placeholder"></div>
      </div>
    </div>

    {%- comment -%} Accordions {%- endcomment -%}
    <div class="bundle-main__accordions" data-bundle-accordions>
      <hr class="bundle-main__divider">

      {% if product_details %}
        <div class="bundle-main__accordion" data-accordion>
          <button
            type="button"
            id="accordion-details-trigger-{{ section.id }}"
            class="bundle-main__accordion-trigger"
            aria-expanded="false"
            aria-controls="accordion-details-{{ section.id }}">
            <span>{{ 'sections.product_bundle.details' | t }}</span>
            <svg class="bundle-main__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
              <path d="M1 8H15M8 1V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            class="bundle-main__accordion-content"
            id="accordion-details-{{ section.id }}"
            role="region"
            aria-labelledby="accordion-details-trigger-{{ section.id }}"
            aria-hidden="true">
            <div class="bundle-main__accordion-body">
              {{ product_details }}
            </div>
          </div>
          <hr class="bundle-main__divider">
        </div>
      {% endif %}

      {% if scent_notes %}
        <div class="bundle-main__accordion" data-accordion>
          <button
            type="button"
            id="accordion-scent-trigger-{{ section.id }}"
            class="bundle-main__accordion-trigger"
            aria-expanded="false"
            aria-controls="accordion-scent-{{ section.id }}">
            <span>{{ 'sections.product_bundle.scent_notes' | t }}</span>
            <svg class="bundle-main__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
              <path d="M1 8H15M8 1V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            class="bundle-main__accordion-content"
            id="accordion-scent-{{ section.id }}"
            role="region"
            aria-labelledby="accordion-scent-trigger-{{ section.id }}"
            aria-hidden="true">
            <div class="bundle-main__accordion-body">
              {{ scent_notes }}
            </div>
          </div>
          <hr class="bundle-main__divider">
        </div>
      {% endif %}

      {% if key_ingredients %}
        <div class="bundle-main__accordion is-open" data-accordion>
          <button
            type="button"
            id="accordion-ingredients-trigger-{{ section.id }}"
            class="bundle-main__accordion-trigger"
            aria-expanded="true"
            aria-controls="accordion-ingredients-{{ section.id }}">
            <span>{{ 'sections.product_bundle.key_ingredients' | t }}</span>
            <svg class="bundle-main__accordion-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
              <path d="M1 8H15M8 1V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            class="bundle-main__accordion-content"
            id="accordion-ingredients-{{ section.id }}"
            role="region"
            aria-labelledby="accordion-ingredients-trigger-{{ section.id }}"
            aria-hidden="false">
            <div class="bundle-main__accordion-body">
              {{ key_ingredients }}
              {% if full_ingredient_list %}
                <button
                  type="button"
                  class="bundle-main__ingredients-link"
                  data-open-ingredients
                  aria-haspopup="dialog">
                  {{ 'sections.product_bundle.all_ingredients' | t }}
                </button>
              {% endif %}
            </div>
          </div>
          <hr class="bundle-main__divider">
        </div>
      {% endif %}
    </div>

    {%- comment -%} Trust Badges {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="bundle-main__badges">
        {% for block in section.blocks %}
          {% if block.type == 'trust_badge' %}
            <div class="bundle-main__badge" {{ block.shopify_attributes }}>
              {% if block.settings.icon %}
                <span
                  class="bundle-main__badge-icon"
                  role="img"
                  aria-label="{{ block.settings.label | default: '' }}"
                  style="-webkit-mask-image: url('{{ block.settings.icon | image_url: width: 60 }}'); mask-image: url('{{ block.settings.icon | image_url: width: 60 }}');">
                </span>
              {% endif %}
              {% if block.settings.label %}
                <p class="bundle-main__badge-label">{{ block.settings.label }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {%- comment -%} Ingredients Popup {%- endcomment -%}
  {% if full_ingredient_list %}
    <dialog
      class="bundle-main__dialog"
      id="ingredients-dialog-{{ section.id }}"
      scroll-lock
      aria-labelledby="dialog-title-{{ section.id }}">
      <div class="bundle-main__dialog-inner">
        <div class="bundle-main__dialog-header">
          <h2 id="dialog-title-{{ section.id }}" class="bundle-main__dialog-title">{{ 'sections.product_bundle.ingredients_popup_title' | t }}</h2>
          <button
            type="button"
            class="bundle-main__dialog-close"
            data-close-ingredients
            aria-label="{{ 'sections.product_bundle.close' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M2 2L18 18M18 2L2 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="bundle-main__dialog-body">
          {{ full_ingredient_list }}
        </div>
      </div>
    </dialog>
  {% endif %}

  {%- comment -%} Product data JSON for JS {%- endcomment -%}
  {% if scent_collection %}
    <script type="application/json" data-bundle-products>
      {
        "bundleVariantId": {{ current_variant.id | json }},
        "scents": {
          {% for scent_product in scent_collection.products %}
            "{{ scent_product.handle }}": {
              "title": {{ scent_product.title | json }},
              "variantId": {{ scent_product.selected_or_first_available_variant.id | json }},
              "variantGid": {{ scent_product.selected_or_first_available_variant.id | prepend: 'gid://shopify/ProductVariant/' | json }},
              {%- if scent_product.metafields.custom.card_image != blank -%}
                "cardImage": {{ scent_product.metafields.custom.card_image | image_url: width: 800 | json }},
              {%- elsif scent_product.featured_image -%}
                "cardImage": {{ scent_product.featured_image | image_url: width: 800 | json }},
              {%- else -%}
                "cardImage": "",
              {%- endif -%}
              "price": {{ scent_product.price | json }},
              "available": {{ scent_product.available | json }},
              "variantAvailable": {{ scent_product.selected_or_first_available_variant.available | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        }
      }
    </script>
  {% endif %}
</section>

{% stylesheet %}
  .bundle-main {
    display: grid;
    grid-template-columns: 55% 45%;
    background: linear-gradient(to bottom, var(--gradient-1) 1.4%, var(--gradient-2) 55%);
    margin-top: var(--total-header-height, 110px);
    min-height: calc(100vh - var(--total-header-height, 110px));
    color: var(--product-text, #3E2027);
  }

  .bundle-main__mobile-header {
    display: none;
  }

  /* --- Image Column --- */

  .bundle-main__image-column {
    position: sticky;
    top: var(--total-header-height, 110px);
    height: calc(100vh - var(--total-header-height, 110px));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .bundle-main__bottles {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: 100%;
    max-width: 700px;
  }

  .bundle-main__bottle-slot {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 -70px;
  }

  .bundle-main__bottle-img {
    width: 100%;
    height: auto;
    max-height: 600px;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }

  .bundle-main__bottle-placeholder {
    width: 55%;
    aspect-ratio: 3 / 5;
    border: 2px dashed var(--product-text, #3E2027);
    border-radius: 40% 40% 10% 10%;
    opacity: 0.15;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bundle-main__bottle-number {
    font-family: var(--font-alyona);
    font-size: 48px;
    opacity: 0.5;
  }

  /* --- Info Column --- */

  .bundle-main__info-column {
    padding: 120px 40px 60px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .bundle-main__desktop-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bundle-main__subtitle {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 20px;
    line-height: normal;
    letter-spacing: -0.2px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
    margin: 0;
  }

  .bundle-main__title {
    font-family: var(--font-alyona);
    font-weight: 400;
    font-size: 74px;
    line-height: 1;
    color: var(--product-text, #3E2027);
    margin: 0;
  }

  .bundle-main__size,
  .bundle-main__size-line {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 20px;
    line-height: normal;
    letter-spacing: -0.2px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
    margin: 0;
  }

  /* --- Scent Selectors --- */

  .bundle-main__selectors {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bundle-main__selector {
    position: relative;
    width: 255px;
  }

  .bundle-main__selector-trigger {
    width: 100%;
    height: 40px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.14px;
    color: var(--product-text, #3E2027);
    background: transparent;
    border: 1px solid var(--product-text, #3E2027);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .bundle-main__selector.is-selected .bundle-main__selector-trigger {
    background-color: #FFFFFF;
    border-color: transparent;
  }

  .bundle-main__selector-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .bundle-main__selector-trigger[aria-expanded="true"] .bundle-main__selector-chevron {
    transform: rotate(180deg);
  }

  .bundle-main__selector-list {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #FFFFFF;
    border: 1px solid var(--product-text, #3E2027);
    list-style: none;
    margin: 0;
    padding: 0;
    z-index: 10;
    max-height: none;
    overflow-y: visible;
  }

  .bundle-main__selector-trigger[aria-expanded="true"] + .bundle-main__selector-list {
    display: block;
  }

  .bundle-main__selector-option {
    padding: 10px 20px;
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.14px;
    color: var(--product-text, #3E2027);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .bundle-main__selector-option:hover {
    background-color: var(--gradient-1);
  }

  .bundle-main__selector-option[aria-disabled="true"] {
    opacity: 0.35;
    text-decoration: line-through;
    cursor: not-allowed;
    pointer-events: none;
  }

  .bundle-main__selector-option[aria-selected="true"] {
    font-weight: 700;
  }

  /* --- Divider --- */

  .bundle-main__divider {
    border: none;
    border-top: 1px solid var(--product-text, #3E2027);
    opacity: 0.2;
    margin: 0;
  }

  /* --- Purchase Row --- */

  .bundle-main__purchase-row {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .bundle-main__price {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 26px;
    letter-spacing: -0.26px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
    margin: 0;
    white-space: nowrap;
  }

  .bundle-main__actions {
    display: flex;
    gap: 10px;
    flex: 1;
  }

  .bundle-main__button {
    flex: 1;
    height: 40px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    line-height: normal;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .bundle-main__button:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .bundle-main__button:active:not(:disabled) {
    opacity: 0.8;
    transform: translateY(0);
  }

  .bundle-main__button--add {
    background-color: #FFFFFF;
    color: var(--product-text, #3E2027);
  }

  .bundle-main__button--buy {
    background-color: var(--product-text, #3E2027);
    color: #FFFFFF;
  }

  .bundle-main__button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .bundle-main__button:focus-visible {
    outline: 2px solid var(--product-text, #3E2027);
    outline-offset: 2px;
  }

  .bundle-main__status {
    width: 100%;
    margin: 10px 0 0;
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 12px;
    line-height: 1.3;
    color: #B42318;
  }

  /* --- Watch It In Action --- */

  .bundle-main__video-section {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  .bundle-main__video-heading {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
    margin: 0;
  }

  .bundle-main__video-grid {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .bundle-main__video-placeholder {
    width: 90px;
    height: 125px;
    background-color: #D9D9D9;
    flex-shrink: 0;
  }

  /* --- Accordions --- */

  .bundle-main__accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
  }

  .bundle-main__accordion-trigger:focus-visible {
    outline: 2px solid var(--product-text, #3E2027);
    outline-offset: 2px;
  }

  .bundle-main__accordion-icon {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .bundle-main__accordion.is-open .bundle-main__accordion-icon {
    transform: rotate(45deg);
  }

  .bundle-main__accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .bundle-main__accordion.is-open .bundle-main__accordion-content {
    grid-template-rows: 1fr;
  }

  .bundle-main__accordion-body {
    overflow: hidden;
    font-family: var(--font-jokker);
    font-size: 14px;
    line-height: 1.5;
    color: var(--product-text, #3E2027);
    padding-bottom: 0;
  }

  .bundle-main__accordion.is-open .bundle-main__accordion-body {
    padding-bottom: 15px;
  }

  .bundle-main__ingredients-link {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-jokker);
    font-size: 14px;
    line-height: 1.5;
    color: var(--product-text, #3E2027);
    text-decoration: underline;
    cursor: pointer;
    margin-top: 4px;
    display: inline-block;
  }

  /* --- Trust Badges --- */

  .bundle-main__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 10px;
  }

  .bundle-main__badge {
    width: 130px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .bundle-main__badge-icon {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    display: block;
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    background-color: var(--product-text, #3E2027);
  }

  .bundle-main__badge-label {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: -0.12px;
    text-transform: uppercase;
    color: var(--product-text, #3E2027);
    margin: 0;
    line-height: normal;
    white-space: pre-line;
  }

  /* --- Ingredients Dialog --- */

  .bundle-main__dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    border: none;
    padding: 0;
    margin: 0;
    background: transparent;
    z-index: 999;
  }

  .bundle-main__dialog::backdrop {
    background-color: rgba(62, 32, 39, 0.5);
  }

  .bundle-main__dialog-inner {
    position: absolute;
    right: 0;
    top: 0;
    width: 100%;
    max-width: 500px;
    height: 100%;
    background: #FFFFFF;
    color: var(--popup-text, #3E2027);
    padding: 40px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .bundle-main__dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bundle-main__dialog-title {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 20px;
    text-transform: uppercase;
    letter-spacing: -0.2px;
    color: var(--popup-text, #3E2027);
    margin: 0;
  }

  .bundle-main__dialog-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--popup-text, #3E2027);
  }

  .bundle-main__dialog-body {
    font-family: var(--font-jokker);
    font-size: 14px;
    line-height: 1.6;
    color: var(--popup-text, #3E2027);
  }

  /* ============================================
     Responsive — Tablet
     ============================================ */

  @media (max-width: 1200px) {
    .bundle-main__info-column {
      padding: 80px 24px 40px;
    }

    .bundle-main__title {
      font-size: 56px;
    }

    .bundle-main__selector {
      width: 100%;
    }
  }

  /* ============================================
     Responsive — Mobile (< 900px)
     ============================================ */

  @media (max-width: 900px) {
    .bundle-main {
      grid-template-columns: 1fr;
    }

    .bundle-main__mobile-header {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 52px 12px 0;
    }

    .bundle-main__mobile-subtitle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .bundle-main__mobile-subtitle-row .bundle-main__subtitle {
      font-size: 16px;
      letter-spacing: -0.16px;
    }

    .bundle-main__mobile-subtitle-row .bundle-main__size {
      font-size: 16px;
      letter-spacing: -0.16px;
      text-align: right;
    }

    .bundle-main__mobile-header .bundle-main__title {
      font-size: 34px;
    }

    .bundle-main__desktop-header {
      display: none;
    }

    .bundle-main__image-column {
      position: relative;
      top: auto;
      height: auto;
      padding: 20px 12px 30px;
    }

    .bundle-main__bottles {
      max-width: 416px;
    }

    .bundle-main__bottle-slot {
      margin: 0 -30px;
    }

    .bundle-main__bottle-img {
      max-height: 340px;
    }

    .bundle-main__bottle-placeholder {
      width: 45%;
      aspect-ratio: 3 / 4;
    }

    .bundle-main__bottle-number {
      font-size: 32px;
    }

    .bundle-main__info-column {
      padding: 0 12px 40px;
      max-width: 100%;
    }

    .bundle-main__selector {
      width: 100%;
    }

    .bundle-main__price {
      font-size: 20px;
      letter-spacing: -0.2px;
    }

    .bundle-main__button {
      font-size: 12px;
      letter-spacing: -0.12px;
    }

    .bundle-main__dialog-inner {
      max-width: 100%;
      padding: 24px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    class BundleSection {
      constructor(section) {
        this.section = section;
        this.bundleSize = parseInt(section.getAttribute('data-bundle-size')) || 3;
        this.selections = {};
        this.productData = {};

        this.parseProductData();
        this.initSelectors();
        this.initAccordions();
        this.initIngredientsDialog();
        this.initCartButtons();
      }

      parseProductData() {
        const jsonEl = this.section.querySelector('[data-bundle-products]');
        if (jsonEl) {
          try {
            const data = JSON.parse(jsonEl.textContent);
            this.productData = data.scents || {};
            this.bundleVariantId = data.bundleVariantId;
          } catch (e) {
            console.error('Bundle: failed to parse product data', e);
          }
        }
      }

      initSelectors() {
        this.selectors = this.section.querySelectorAll('[data-scent-selector]');
        this.selectors.forEach(selector => {
          const trigger = selector.querySelector('.bundle-main__selector-trigger');
          const options = selector.querySelectorAll('.bundle-main__selector-option');
          const selectorIndex = selector.getAttribute('data-scent-selector');

          trigger.addEventListener('click', () => this.toggleDropdown(selector));

          options.forEach(option => {
            option.addEventListener('click', () => {
              if (option.getAttribute('aria-disabled') === 'true') return;
              this.selectScent(selector, selectorIndex, option);
            });
          });
        });

        document.addEventListener('click', (e) => {
          if (!e.target.closest('[data-scent-selector]')) {
            this.closeAllDropdowns();
          }
        });

        this.syncDisabledStates();
      }

      toggleDropdown(selector) {
        const trigger = selector.querySelector('.bundle-main__selector-trigger');
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        this.closeAllDropdowns();

        if (!isOpen) {
          trigger.setAttribute('aria-expanded', 'true');
        }
      }

      closeAllDropdowns() {
        this.selectors.forEach(s => {
          s.querySelector('.bundle-main__selector-trigger').setAttribute('aria-expanded', 'false');
        });
      }

      selectScent(selector, selectorIndex, option) {
        const handle = option.getAttribute('data-product-handle');
        let product = this.productData[handle];
        if (!product) {
          const variantId = option.getAttribute('data-variant-id');
          if (!variantId) return;
          product = {
            title: option.getAttribute('data-product-title') || option.textContent.trim(),
            variantId: variantId,
            variantGid: option.getAttribute('data-variant-gid') || ('gid://shopify/ProductVariant/' + variantId),
            cardImage: option.getAttribute('data-card-image') || '',
          };
          this.productData[handle] = product;
        }
        if (!product) return;

        this.selections[selectorIndex] = handle;

        const label = selector.querySelector('[data-selector-label]');
        label.textContent = selectorIndex + '. ' + product.title;
        selector.classList.add('is-selected');

        option.setAttribute('aria-selected', 'true');
        selector.querySelectorAll('.bundle-main__selector-option').forEach(opt => {
          if (opt !== option) opt.setAttribute('aria-selected', 'false');
        });

        this.closeAllDropdowns();
        this.syncDisabledStates();
        this.updateBottleImage(selectorIndex, product);
        this.updateButtons();
      }

      syncDisabledStates() {
        this.selectors.forEach(selector => {
          selector.querySelectorAll('.bundle-main__selector-option').forEach(option => {
            option.setAttribute('aria-disabled', 'false');
          });
        });
      }

      updateBottleImage(selectorIndex, product) {
        const slot = this.section.querySelector('[data-bottle-slot="' + selectorIndex + '"]');
        if (!slot) return;

        const img = slot.querySelector('.bundle-main__bottle-img');
        const placeholder = slot.querySelector('.bundle-main__bottle-placeholder');

        if (product.cardImage) {
          img.src = product.cardImage;
          img.alt = product.title;
          img.style.display = 'block';
          if (placeholder) placeholder.style.display = 'none';
        }
      }

      updateButtons() {
        const allSelected = Object.keys(this.selections).length >= this.bundleSize;
        const canAdd = allSelected;
        const addBtn = this.section.querySelector('[data-bundle-add]');
        const buyBtn = this.section.querySelector('[data-bundle-buy]');

        if (addBtn) addBtn.disabled = !canAdd;
        if (buyBtn) buyBtn.disabled = !canAdd;
      }

      getSelectedProducts() {
        return Object.entries(this.selections).map(([index, handle]) => {
          const product = this.productData[handle];
          return product ? { index, ...product } : null;
        }).filter(Boolean);
      }

      initCartButtons() {
        const addBtn = this.section.querySelector('[data-bundle-add]');
        const buyBtn = this.section.querySelector('[data-bundle-buy]');

        if (addBtn) {
          addBtn.addEventListener('click', () => this.addToCart(false));
        }
        if (buyBtn) {
          buyBtn.addEventListener('click', () => this.addToCart(true));
        }
      }

      async addToCart(goToCart) {
        const selected = this.getSelectedProducts();
        if (selected.length < this.bundleSize) return;
        if (!this.bundleVariantId) {
          console.error('Bundle: no bundle variant ID found');
          return;
        }

        const addBtn = this.section.querySelector('[data-bundle-add]');
        const buyBtn = this.section.querySelector('[data-bundle-buy]');
        if (addBtn) addBtn.disabled = true;
        if (buyBtn) buyBtn.disabled = true;

        try {
          const ordinals = ['First', 'Second', 'Third', 'Fourth', 'Fifth'];
          const properties = {};
          selected.forEach((p, i) => {
            properties[ordinals[i] + ' Scent'] = p.title;
          });

          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              items: [{
                id: this.bundleVariantId,
                quantity: 1,
                properties: properties
              }]
            })
          });

          if (!response.ok) {
            const errorData = await response.json().catch(() => null);
            console.error('Bundle: cart response', response.status, errorData);
            throw new Error('Failed to add to cart');
          }

          if (goToCart) {
            window.location.href = '/cart';
          } else {
            const cartResponse = await fetch('/cart.js');
            const cartData = await cartResponse.json();
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: cartData }));
            document.dispatchEvent(new CustomEvent('cart:open'));
            if (addBtn) addBtn.disabled = false;
            if (buyBtn) buyBtn.disabled = false;
          }
        } catch (error) {
          console.error('Bundle: add to cart failed', error);
          if (addBtn) addBtn.disabled = false;
          if (buyBtn) buyBtn.disabled = false;
        }
      }

      initAccordions() {
        const accordions = this.section.querySelectorAll('[data-accordion]');
        accordions.forEach(accordion => {
          const trigger = accordion.querySelector('.bundle-main__accordion-trigger');
          if (!trigger) return;

          trigger.addEventListener('click', () => {
            const isOpen = accordion.classList.contains('is-open');
            accordion.classList.toggle('is-open');
            trigger.setAttribute('aria-expanded', !isOpen);

            const content = accordion.querySelector('.bundle-main__accordion-content');
            if (content) {
              content.setAttribute('aria-hidden', isOpen);
            }
          });
        });
      }

      initIngredientsDialog() {
        const sectionId = this.section.getAttribute('data-section-id');
        const dialog = this.section.querySelector('#ingredients-dialog-' + sectionId);
        if (!dialog) return;

        const openBtn = this.section.querySelector('[data-open-ingredients]');
        const closeBtn = this.section.querySelector('[data-close-ingredients]');

        if (openBtn) {
          openBtn.addEventListener('click', () => dialog.showModal());
        }
        if (closeBtn) {
          closeBtn.addEventListener('click', () => dialog.close());
        }
        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) dialog.close();
        });
      }
    }

    function init() {
      const section = document.querySelector('.bundle-main');
      if (section) new BundleSection(section);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('shopify:section:load', (e) => {
      if (e.target.querySelector('.bundle-main')) {
        init();
      }
    });
  })();
{% endjavascript %}

