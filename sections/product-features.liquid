{% comment %}
  Product Features Section
  Displays product badges/features in an infinite marquee
{% endcomment %}

<div class="product-features full-width" style="--section-bg: {{ section.settings.background_color }}; --text-color: {{ section.settings.text_color }}; --icon-color: {{ section.settings.icon_color | default: section.settings.text_color }};">
  <div class="product-features__container">
    {% if section.blocks.size > 0 %}
      <div class="product-features__viewport">
        <div class="product-features__track" data-features-marquee>
          <div class="product-features__group">
            {% for block in section.blocks %}
              {% if block.type == 'feature_badge' %}
                <div class="product-features__item" {{ block.shopify_attributes }}>
                  {% if block.settings.icon %}
                    <span
                      class="product-features__icon"
                      role="img"
                      aria-label="{{ block.settings.icon_alt | default: block.settings.text | strip_newlines }}"
                      style="-webkit-mask-image: url('{{ block.settings.icon | image_url: width: 80 }}'); mask-image: url('{{ block.settings.icon | image_url: width: 80 }}');">
                    </span>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <p class="product-features__text">{{ block.settings.text }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-features {
    background-color: #FCE9EC;
    padding: 0;
  }

  .product-features__container {
    margin: 0 auto;
    background-color: var(--section-bg, #3E2027);
  }

  .product-features__viewport {
    overflow: hidden;
    position: relative;
  }

  .product-features__track {
    display: flex;
    align-items: center;
    width: max-content;
    white-space: nowrap;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .product-features__track.is-ready {
    animation: features-marquee var(--marquee-duration, 40s) linear infinite;
  }

  .product-features__group {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 0 20px;
    height: 90px;
  }

  .product-features__item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .product-features__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: inline-block;
    background-color: var(--icon-color, var(--text-color, #FFFFFF));
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  .product-features__text {
    font-family: var(--font-sweet-sans);
    font-weight: 500;
    font-size: 14px;
    line-height: normal;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    color: var(--text-color, #FFFFFF);
    white-space: pre-line;
    margin: 0;
  }

  @keyframes features-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(calc(-1 * var(--marquee-distance)), 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-features__track.is-ready {
      animation: none;
      transform: translateX(0);
      justify-content: center;
    }

    .product-features__group[aria-hidden="true"] {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .product-features__group {
      gap: 30px;
      padding: 0 15px;
      height: 70px;
    }

    .product-features__icon {
      width: 32px;
      height: 32px;
    }

    .product-features__text {
      font-size: 12px;
      letter-spacing: -0.12px;
    }
  }
{% endstylesheet %}

{% javascript %}
  class FeaturesMarquee {
    constructor() {
      this.sections = Array.from(document.querySelectorAll('.product-features'));
      if (!this.sections.length) return;

      this.init();
      this.setupResizeHandler();
    }

    init() {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => requestAnimationFrame(() => this.buildAll()));
      } else {
        requestAnimationFrame(() => this.buildAll());
      }
    }

    buildAll() {
      this.sections.forEach((section) => this.buildMarquee(section));
    }

    buildMarquee(section) {
      const viewport = section.querySelector('.product-features__viewport');
      const track = section.querySelector('[data-features-marquee]');
      const group = track && track.querySelector('.product-features__group');
      if (!viewport || !track || !group) return;

      track.querySelectorAll('.product-features__group[aria-hidden="true"]').forEach((n) => n.remove());

      track.classList.remove('is-ready');
      track.style.animation = 'none';
      track.style.transform = 'translate3d(0,0,0)';

      void track.offsetHeight;

      const viewportWidth = viewport.getBoundingClientRect().width;
      const groupWidth = group.getBoundingClientRect().width;

      if (!groupWidth || !viewportWidth) return;

      let totalWidth = groupWidth;
      const targetWidth = viewportWidth * 3;

      while (totalWidth < targetWidth) {
        const clone = group.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
        totalWidth += groupWidth;
      }

      const distance = Math.ceil(groupWidth);
      track.style.setProperty('--marquee-distance', `${distance}px`);

      const speed = 25;
      const duration = Math.max(20, distance / speed);
      track.style.setProperty('--marquee-duration', `${duration}s`);

      track.style.animation = '';
      track.classList.add('is-ready');
    }

    setupResizeHandler() {
      let resizeTimer;
      let lastWidth = window.innerWidth;
      window.addEventListener('resize', () => {
        const newWidth = window.innerWidth;
        if (newWidth === lastWidth) return;
        lastWidth = newWidth;
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => this.buildAll(), 150);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new FeaturesMarquee());
  } else {
    new FeaturesMarquee();
  }
{% endjavascript %}

{% schema %}
  {
    "name": "t:sections.product_features.name",
    "class": "product-features-section",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.colors"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "t:labels.background_color",
        "default": "#3E2027"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "t:labels.text_color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "icon_color",
        "label": "t:sections.product_features.settings.icon_color",
        "default": "#FFFFFF"
      }
    ],
    "blocks": [
      {
        "type": "feature_badge",
        "name": "t:sections.product_features.blocks.feature_badge.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "t:sections.product_features.blocks.feature_badge.settings.icon.label"
          }, {
            "type": "text",
            "id": "icon_alt",
            "label": "t:sections.product_features.blocks.feature_badge.settings.icon_alt.label",
            "info": "t:sections.product_features.blocks.feature_badge.settings.icon_alt.info",
            "default": "Feature icon"
          }, {
            "type": "textarea",
            "id": "text",
            "label": "t:sections.product_features.blocks.feature_badge.settings.text.label",
            "info": "t:sections.product_features.blocks.feature_badge.settings.text.info",
            "default": "Feature\nText"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "t:sections.product_features.name",
        "blocks": [
          {
            "type": "feature_badge",
            "settings": {
              "text": "Aluminum\nFree"
            }
          },
          {
            "type": "feature_badge",
            "settings": {
              "text": "Paraben\nFree"
            }
          },
          {
            "type": "feature_badge",
            "settings": {
              "text": "Sulfate\nFree"
            }
          },
          {
            "type": "feature_badge",
            "settings": {
              "text": "Cruelty\nFree"
            }
          }, {
            "type": "feature_badge",
            "settings": {
              "text": "Phthalate\nFree"
            }
          }, {
            "type": "feature_badge",
            "settings": {
              "text": "Plant-Based\nIngredients"
            }
          }, {
            "type": "feature_badge",
            "settings": {
              "text": "Vegan"
            }
          }
        ]
      }
    ]
  }
{% endschema %}
