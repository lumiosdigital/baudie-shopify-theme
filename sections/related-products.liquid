{%- liquid
  assign max_products = section.settings.max_products | default: 4
  assign collection_products = blank
  assign is_cart = false

  if template.name == 'cart'
    assign is_cart = true
    for cart_item in cart.items
      if cart_item.product.collections.first != blank
        assign collection_products = cart_item.product.collections.first.products
        break
      endif
    endfor
  elsif product.collections.first != blank
    assign collection_products = product.collections.first.products
  endif

  assign related_count = 0
  for item in collection_products
    if is_cart
      assign skip = false
      for cart_item in cart.items
        if cart_item.product.id == item.id
          assign skip = true
          break
        endif
      endfor
      unless skip
        assign related_count = related_count | plus: 1
      endunless
    else
      if item.id != product.id
        assign related_count = related_count | plus: 1
      endif
    endif
  endfor
-%}

{%- if related_count > 0 -%}
  <related-products class="related-products full-width" style="--section-bg: {{ section.settings.background_color }}; --text-color: {{ section.settings.text_color }};">
    <div class="related-products__wrapper">
      {%- if section.settings.heading != blank -%}
        <h2 class="related-products__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <div class="related-products__track" data-track aria-label="{{ 'sections.related_products.aria_label' | t }}">
        {%- assign card_index = 0 -%}
        {%- for item in collection_products -%}
          {%- liquid
            assign should_show = false
            if is_cart
              assign in_cart = false
              for cart_item in cart.items
                if cart_item.product.id == item.id
                  assign in_cart = true
                  break
                endif
              endfor
              unless in_cart
                assign should_show = true
              endunless
            else
              if item.id != product.id
                assign should_show = true
              endif
            endif
          -%}
          {%- if should_show and card_index < max_products -%}
            {%- assign card_bg = item.metafields.custom.product_card_background | default: '#FCF0D2' -%}
            {%- assign card_image = item.metafields.custom.card_image | default: item.featured_image -%}
            {%- assign card_hover_image = item.metafields.custom.card_hover_image -%}
            {%- assign short_description = item.metafields.custom.short_description | default: item.description | strip_html | truncate: 120 -%}
            {%- assign selected_variant = item.selected_or_first_available_variant -%}
            <div class="related-products__card" data-card>
              <div class="related-products__image" style="background-color: {{ card_bg }};">
                <a href="{{ item.url }}" class="related-products__image-link" aria-label="{{ item.title }}">
                  {%- if card_image -%}
                    {{ card_image | image_url: width: 500 | image_tag:
                      loading: 'lazy',
                      class: 'related-products__img',
                      alt: card_image.alt | default: item.title,
                      width: 247,
                      height: 370
                    }}
                  {%- else -%}
                    <div class="related-products__placeholder">
                      {{ 'product-1' | placeholder_svg_tag: 'related-products__placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </a>
                {%- if card_hover_image -%}
                  <div class="related-products__hover-image">
                    {{ card_hover_image | image_url: width: 600 | image_tag:
                      loading: 'lazy',
                      class: 'related-products__hover-img',
                      alt: card_hover_image.alt | default: item.title
                    }}
                  </div>
                {%- endif -%}
                <div class="related-products__actions">
                  {%- form 'product', item, class: 'related-products__form' -%}
                    <input type="hidden" name="id" value="{{ selected_variant.id }}">
                    <button
                      type="submit"
                      name="add"
                      class="related-products__action-btn related-products__action-btn--add"
                      aria-label="{{ 'products.add_to_cart' | t }}: {{ item.title }}"
                      {% unless selected_variant.available %}disabled aria-disabled="true"{% endunless %}>
                      <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M0.75 7.75H14.75M7.75 0.75V14.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                      <span>{{ 'products.add_to_cart' | t }}</span>
                    </button>
                  {%- endform -%}
                  {%- form 'product', item, class: 'related-products__form' -%}
                    <input type="hidden" name="id" value="{{ selected_variant.id }}">
                    <input type="hidden" name="return_to" value="/cart">
                    <button
                      type="submit"
                      class="related-products__action-btn related-products__action-btn--buy"
                      aria-label="{{ 'products.buy_now' | t }}: {{ item.title }}"
                      {% unless selected_variant.available %}disabled{% endunless %}>
                      {{ 'products.buy_now' | t }}
                    </button>
                  {%- endform -%}
                </div>
              </div>
              <div class="related-products__info">
                <div class="related-products__meta">
                  <h3 class="related-products__title">
                    <a href="{{ item.url }}" class="related-products__title-link">{{ item.title }}</a>
                  </h3>
                  <span class="related-products__price">{{ item.price | money }}</span>
                </div>
                {%- if short_description != blank -%}
                  <p class="related-products__description">{{ short_description }}</p>
                {%- endif -%}
              </div>
            </div>
            {%- assign card_index = card_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if related_count > 1 -%}
        <div class="related-products__dots" data-dots>
          {%- assign dot_count = max_products -%}
          {%- if related_count < max_products -%}
            {%- assign dot_count = related_count -%}
          {%- endif -%}
          {%- for i in (1..dot_count) -%}
            <button
              class="related-products__dot{% if forloop.first %} is-active{% endif %}"
              data-dot="{{ forloop.index0 }}"
              aria-label="{{ 'sections.related_products.pagination_label' | t }} {{ forloop.index }}">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </related-products>
{%- endif -%}

{% stylesheet %}
  .related-products {
    background-color: var(--section-bg, #FFF7EA);
    padding: 53px 0 0;
  }

  .related-products__wrapper {
    max-width: 1600px;
    margin: 0 auto 90px;
    padding: 0 40px;
  }

  .related-products__heading {
    font-family: var(--font-alyona);
    font-size: 70px;
    font-weight: 400;
    line-height: 1;
    color: var(--text-color, #3E2027);
    margin: 0 0 40px;
  }

  .related-products__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .related-products__card {
    display: flex;
    flex-direction: column;
    gap: 30px;
    color: var(--text-color, #3E2027);
  }

  .related-products__image {
    position: relative;
    height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .related-products__image-link {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .related-products__img {
    width: 247px;
    height: 370px;
    object-fit: contain;
  }

  .related-products__placeholder {
    width: 247px;
    height: 370px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
  }

  /* Hover Image */
  .related-products__hover-image {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .related-products__hover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-products__image:hover .related-products__hover-image {
    opacity: 1;
  }

  /* Hover Actions */
  .related-products__actions {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 15px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 5;
  }

  .related-products__image:hover .related-products__actions,
  .related-products__image:focus-within .related-products__actions {
    opacity: 1;
    transform: translateY(0);
  }

  .related-products__form {
    display: contents;
  }

  .related-products__action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 40px;
    padding: 10px 20px;
    font-family: var(--font-sweet-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.14px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .related-products__action-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .related-products__action-btn:focus-visible {
    outline: 2px solid var(--text-color, #3E2027);
    outline-offset: 2px;
  }

  .related-products__action-btn--add {
    background-color: #FFFFFF;
    color: var(--text-color, #3E2027);
  }

  .related-products__action-btn--add:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .related-products__action-btn--buy {
    background-color: var(--text-color, #3E2027);
    color: #FFFFFF;
  }

  .related-products__title-link {
    color: inherit;
    text-decoration: none;
  }

  .related-products__title-link:hover {
    text-decoration: underline;
  }

  .related-products__title-link:focus-visible {
    outline: 2px solid var(--text-color, #3E2027);
    outline-offset: 2px;
  }

  .related-products__info {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .related-products__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .related-products__title {
    font-family: var(--font-sweet-sans);
    font-size: 18px;
    font-weight: 500;
    line-height: normal;
    letter-spacing: -0.18px;
    text-transform: uppercase;
    margin: 0;
    flex: 1;
  }

  .related-products__price {
    font-family: var(--font-sweet-sans);
    font-size: 18px;
    font-weight: 400;
    line-height: normal;
    letter-spacing: -0.18px;
    text-align: right;
    white-space: nowrap;
  }

  .related-products__description {
    font-family: var(--font-jokker);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .related-products__dots {
    display: none;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .related-products {
      padding: 40px 0 60px;
    }

    .related-products__heading {
      font-size: 50px;
      margin-bottom: 40px;
    }

    .related-products__track {
      grid-template-columns: repeat(2, 1fr);
    }

    .related-products__image {
      height: 340px;
    }

    .related-products__img {
      width: 200px;
      height: 300px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .related-products {
      padding: 43px 0 50px;
    }

    .related-products__wrapper {
      padding: 0;
    }

    .related-products__heading {
      font-size: 34px;
      text-align: center;
      margin: 0 0 24px;
      padding: 0 12px;
    }

    .related-products__track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 4px;
      padding: 0 12px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .related-products__track::-webkit-scrollbar {
      display: none;
    }

    .related-products__card {
      flex: 0 0 calc(50% - 8px);
      scroll-snap-align: start;
      gap: 18px;
    }

    .related-products__image {
      height: 264px;
    }

    .related-products__img {
      width: 155px;
      height: 233px;
    }

    .related-products__info {
      gap: 8px;
    }

    .related-products__title {
      font-size: 14px;
      letter-spacing: -0.14px;
    }

    .related-products__price {
      font-size: 14px;
      letter-spacing: -0.14px;
    }

    .related-products__description {
      font-size: 10px;
      line-height: 1.4;
    }

    .related-products__actions {
      opacity: 1;
      transform: translateY(0);
      flex-direction: column;
      padding: 10px;
      gap: 6px;
    }

    .related-products__action-btn {
      width: 100%;
      height: 36px;
      padding: 8px 12px;
      font-size: 12px;
    }

  }
{% endstylesheet %}

{% javascript %}
  class RelatedProducts extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.dots = this.querySelectorAll('[data-dot]');
      this.cards = this.querySelectorAll('[data-card]');

      if (!this.track || !this.dots.length || !this.cards.length) return;

      this.setupDotClicks();
      this.setupScrollObserver();
    }

    setupDotClicks() {
      this.dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const index = parseInt(dot.dataset.dot, 10);
          const card = this.cards[index];
          if (card) {
            card.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          }
        });
      });
    }

    setupScrollObserver() {
      const options = {
        root: this.track,
        threshold: 0.5
      };

      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const index = Array.from(this.cards).indexOf(entry.target);
            this.setActiveDot(index);
          }
        });
      }, options);

      this.cards.forEach(card => this.observer.observe(card));
    }

    setActiveDot(index) {
      this.dots.forEach(dot => dot.classList.remove('is-active'));
      if (this.dots[index]) {
        this.dots[index].classList.add('is-active');
      }
    }

    disconnectedCallback() {
      if (this.observer) {
        this.observer.disconnect();
      }
    }
  }

  if (!customElements.get('related-products')) {
    customElements.define('related-products', RelatedProducts);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.related_products.name",
  "class": "related-products-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:sections.related_products.settings.max_products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:labels.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#FFF7EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#3E2027"
    }
  ],
  "templates": ["product", "cart"],
  "presets": [
    {
      "name": "t:sections.related_products.name"
    }
  ]
}
{% endschema %}
