  transform: translateY(0);
}{% endstylesheet %}{% javascript %}
class Sidecart {
  constructor() {
    this.sidecart = document.getElementById('sidecart');
    this.overlay = document.getElementById('sidecart-overlay');
    this.closeButton = document.getElementById('sidecart-close');
    this.drawer = this.sidecart?.querySelector('.sidecart__drawer');
    this.content = this.sidecart?.querySelector('[data-sidecart-content]');
    this.itemsContainer = this.sidecart?.querySelector('[data-sidecart-items]');
    this.footer = this.sidecart?.querySelector('[data-sidecart-footer]');
    this.countElement = this.sidecart?.querySelector('[data-sidecart-count]');
    this.itemsLabelElement = this.sidecart?.querySelector('[data-sidecart-items-label]');
    this.subtotalElement = this.sidecart?.querySelector('[data-sidecart-subtotal]');
    this.emptyElement = this.sidecart?.querySelector('[data-sidecart-empty]');
    this.itemSingular = this.sidecart?.dataset.itemSingular || 'item';
    this.itemPlural = this.sidecart?.dataset.itemPlural || 'items';

    this.shippingBarEnabled = this.sidecart?.hasAttribute('data-shipping-bar-enabled') || false;
    this.shippingThreshold = parseInt(this.sidecart?.dataset.shippingThreshold || '0', 10);
    this.shippingProgressMsg = this.sidecart?.dataset.shippingProgressMsg || '';
    this.shippingSuccessMsg = this.sidecart?.dataset.shippingSuccessMsg || '';
    this.shippingBarText = this.sidecart?.querySelector('[data-shipping-bar-text]');
    this.shippingBarFill = this.sidecart?.querySelector('[data-shipping-bar-fill]');
    this.shippingBar = this.sidecart?.querySelector('[data-shipping-bar]');

    this.triggerElement = null;
    this.pendingUpdates = new Map();
    this.updateTimeouts = new Map();
    this.inFlightRequests = 0;
    this.reconcileInFlight = false;
    // Serialize cart mutations: Shopify's cart API is not concurrency-safe, so
    // overlapping /cart/change.js requests can drop updates. Chain them.
    this.mutationChain = Promise.resolve();
    this.pendingMutations = 0;

    if (!this.sidecart) return;
    

    this.bindEvents();
    this.initCartListeners();
  }

  refreshElementRefs() {
    this.content = this.sidecart?.querySelector('[data-sidecart-content]');
    this.itemsContainer = this.sidecart?.querySelector('[data-sidecart-items]');
    this.footer = this.sidecart?.querySelector('[data-sidecart-footer]');
    this.countElement = this.sidecart?.querySelector('[data-sidecart-count]');
    this.itemsLabelElement = this.sidecart?.querySelector('[data-sidecart-items-label]');
    this.subtotalElement = this.sidecart?.querySelector('[data-sidecart-subtotal]');
    this.emptyElement = this.sidecart?.querySelector('[data-sidecart-empty]');
    this.shippingBarText = this.sidecart?.querySelector('[data-shipping-bar-text]');
    this.shippingBarFill = this.sidecart?.querySelector('[data-shipping-bar-fill]');
    this.shippingBar = this.sidecart?.querySelector('[data-shipping-bar]');
  }

  bindEvents() {
    this.closeButton?.addEventListener('click', () => this.close());
    this.overlay?.addEventListener('click', () => this.close());
    document.addEventListener('keydown', (e) => this.handleKeydown(e));

    this.sidecart.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (! btn) return;
      

      const action = btn.dataset.action;
      const key = btn.dataset.key;
      const item = btn.closest('[data-sidecart-item]');
      const qtyEl = item?.querySelector('[data-quantity]');
      const priceEl = item?.querySelector('[data-price]');
      const comparePriceEl = item?.querySelector('[data-compare-price]');
      const currentQty = parseInt(qtyEl?.value || '1', 10);
      const unitPrice = item?.dataset.unitPrice
        ? parseInt(item.dataset.unitPrice, 10)
        : 0;
      const compareUnitPrice = item?.dataset.compareUnitPrice
        ? parseInt(item.dataset.compareUnitPrice, 10)
        : 0;

      let newQty = currentQty;

      const inventory = parseInt(item?.dataset.inventory || '99999', 10);
      const inventoryPolicy = item?.dataset.inventoryPolicy || 'deny';

      if (action === 'increase') {
        if (inventoryPolicy === 'deny' && currentQty >= inventory) {
          this.showStockWarning(item, inventory);
          return;
        }
        newQty = currentQty + 1;
      } else if (action === 'decrease') {
        newQty = currentQty > 1
          ? currentQty - 1
          : 0;
      } else if (action === 'remove') {
        newQty = 0;
      }

      if (newQty === 0) {
        item?.remove();
      } else {
        if (qtyEl) {
          qtyEl.value = newQty;
          qtyEl.defaultValue = newQty;
        }
        if (priceEl && unitPrice) 
          priceEl.textContent = this.formatMoney(unitPrice * newQty);
        
        if (comparePriceEl && compareUnitPrice) 
          comparePriceEl.textContent = this.formatMoney(compareUnitPrice * newQty);
        
      }

      this.updateCountsOptimistic(currentQty, newQty, unitPrice);
      this.queueUpdate(key, newQty);
    });

    this.sidecart.addEventListener('change', (e) => {
      const input = e.target.closest('[data-quantity]');
      if (! input) return;
      

      const key = input.dataset.key;
      const item = input.closest('[data-sidecart-item]');
      const priceEl = item?.querySelector('[data-price]');
      const comparePriceEl = item?.querySelector('[data-compare-price]');
      const unitPrice = item?.dataset.unitPrice
        ? parseInt(item.dataset.unitPrice, 10)
        : 0;
      const compareUnitPrice = item?.dataset.compareUnitPrice
        ? parseInt(item.dataset.compareUnitPrice, 10)
        : 0;

      const oldQty = parseInt(input.defaultValue || '1', 10);
      let newQty = parseInt(input.value || '0', 10);

      if (newQty < 0) 
        newQty = 0;
      
      input.value = newQty;

      if (newQty === 0) {
        item?.remove();
      } else {
        if (priceEl && unitPrice) 
          priceEl.textContent = this.formatMoney(unitPrice * newQty);
        
        if (comparePriceEl && compareUnitPrice) 
          comparePriceEl.textContent = this.formatMoney(compareUnitPrice * newQty);
        
      }

      this.updateCountsOptimistic(oldQty, newQty, unitPrice);
      this.queueUpdate(key, newQty);
      input.defaultValue = newQty;
    });
  }

  queueUpdate(key, quantity) {
    this.pendingUpdates.set(key, quantity);

    if (this.updateTimeouts.has(key)) {
      clearTimeout(this.updateTimeouts.get(key));
    }

    const timeout = setTimeout(() => {
      const finalQty = this.pendingUpdates.get(key);
      this.pendingUpdates.delete(key);
      this.updateTimeouts.delete(key);
      this.pendingMutations++;
      this.mutationChain = this.mutationChain
        .then(() => this.updateQuantity(key, finalQty))
        .catch(() => {})
        .finally(() => { this.pendingMutations--; });
    }, 300);

    this.updateTimeouts.set(key, timeout);
  }

  updateCountsOptimistic(oldQty, newQty, unitPrice) {
    const diff = newQty - oldQty;
    const priceDiff = unitPrice * diff;

    const currentCount = parseInt(this.countElement?.textContent || '0', 10);
    const newCount = currentCount + diff;

    if (this.countElement) 
      this.countElement.textContent = newCount;
    
    this.updateItemsLabel(newCount);

    document.querySelectorAll('[data-cart-count]').forEach(el => {
      el.textContent = newCount;
      el.style.display = newCount > 0
        ? ''
        : 'none';
    });

    if (this.subtotalElement) {
      const currentSubtotal = this.parseMoneyToNumber(this.subtotalElement.textContent);
      const newSubtotal = currentSubtotal + priceDiff;
      this.subtotalElement.textContent = this.formatMoney(newSubtotal);
      this.updateShippingBar(newSubtotal);
    }

    if (newCount === 0) {
      this.showEmptyState();
    }

    this.updateUpsellFromDOM();
  }

  updateShippingBar(cartTotalCents) {
    if (!this.shippingBarEnabled || !this.shippingBarText || !this.shippingBarFill) return;
    

    const threshold = this.shippingThreshold;
    const remaining = Math.max(0, threshold - cartTotalCents);
    const progress = Math.min(100, (cartTotalCents / threshold) * 100);

    this.shippingBarFill.style.width = progress + '%';

    if (remaining <= 0) {
      this.shippingBarText.textContent = this.shippingSuccessMsg;
    } else {
      this.shippingBarText.textContent = this.shippingProgressMsg.replace('[amount]', this.formatMoney(remaining));
    }
  }

  showEmptyState() {
    this.refreshElementRefs();
    if (this.itemsContainer)
      this.itemsContainer.classList.add('sidecart__items--hidden');

    if (this.emptyElement) 
      this.emptyElement.classList.remove('sidecart__empty--hidden');
    
    if (this.footer) 
      this.footer.classList.add('sidecart__footer--hidden');
    
    if (this.shippingBar)
      this.shippingBar.classList.add('sidecart__shipping-bar--hidden');

    const upsellRegion = this.sidecart?.querySelector('[data-sidecart-upsell]');
    if (upsellRegion)
      upsellRegion.hidden = true;
  }

  hideEmptyState() {
    this.refreshElementRefs();
    if (this.itemsContainer) 
      this.itemsContainer.classList.remove('sidecart__items--hidden');
    
    if (this.emptyElement) 
      this.emptyElement.classList.add('sidecart__empty--hidden');
    
    if (this.footer) 
      this.footer.classList.remove('sidecart__footer--hidden');
    
    if (this.shippingBar) 
      this.shippingBar.classList.remove('sidecart__shipping-bar--hidden');
    
  }

  updateItemsLabel(count) {
    if (this.itemsLabelElement) {
      this.itemsLabelElement.textContent = count === 1
        ? this.itemSingular
        : this.itemPlural;
    }
  }

  parseMoneyToNumber(moneyString) {
    const cleaned = moneyString.replace(/[^0-9.,]/g, '').replace(',', '.');
    return Math.round(parseFloat(cleaned) * 100) || 0;
  }

  initCartListeners() {
    document.addEventListener('cart:open', () => this.open());
    document.addEventListener('cart:updated', (e) => { this.refresh(e.detail); this.updateUpsell(); });
    document.addEventListener('cart:dom-updated', () => { this.refreshElementRefs(); this.updateUpsell(); });
    this.updateUpsell();
  }

  applyUpsellVisibility(productIds) {
    const region = this.sidecart?.querySelector('[data-sidecart-upsell]');
    if (!region) return;

    if (productIds.length === 0) {
      region.hidden = true;
      return;
    }

    const excludeIds = (region.dataset.excludeIds || '')
      .split(',')
      .map((s) => s.trim())
      .filter(Boolean);

    const allExcluded = excludeIds.length > 0 && productIds.every((id) => excludeIds.includes(id));
    if (allExcluded) {
      region.hidden = true;
      return;
    }

    let anyVisible = false;
    region.querySelectorAll('[data-sidecart-upsell-offer]').forEach((offer) => {
      const inCart = productIds.includes(String(offer.dataset.productId));
      offer.hidden = inCart;
      if (!inCart) anyVisible = true;
    });

    region.hidden = !anyVisible;
  }

  // Instant: reads the cart line items already in the drawer DOM (no fetch).
  updateUpsellFromDOM() {
    const items = this.sidecart?.querySelectorAll('[data-sidecart-item]') || [];
    const productIds = Array.from(items)
      .map((el) => String(el.dataset.productId))
      .filter((id) => id && id !== 'undefined');
    this.applyUpsellVisibility(productIds);
  }

  // Authoritative: reconciles against the live cart from the server.
  async updateUpsell() {
    if (!this.sidecart?.querySelector('[data-sidecart-upsell]')) return;
    let cart;
    try {
      cart = await fetch('/cart.js', { cache: 'no-store' }).then((r) => r.json());
    } catch (e) {
      return;
    }
    this.applyUpsellVisibility((cart?.items || []).map((i) => String(i.product_id)));
  }

  // Reconcile the drawer against the authoritative cart when it opens, so a
  // stale/ghost line item can never be shown. Skipped while an add is in
  // flight (is-loading) so it never clobbers an in-progress add.
  async reconcileOnOpen() {
    // Skip while a cart mutation is still settling (is-loading add, or a
    // serialized remove/change chain) so we never reconcile against an
    // intermediate server state and re-render ghost items.
    if (this.sidecart?.classList.contains('is-loading') || this.reconcileInFlight || this.pendingMutations > 0) return;
    this.reconcileInFlight = true;
    try {
      let cart;
      try {
        cart = await fetch('/cart.js', { cache: 'no-store' }).then((r) => r.json());
      } catch (e) {
        return;
      }
      if (!cart || this.sidecart?.classList.contains('is-loading')) return;

      const domItemCount = this.sidecart?.querySelectorAll('[data-sidecart-item]').length || 0;

      if (cart.item_count === 0) {
        this.showEmptyState();
        // Authoritative empty: drop any stale ghost line items from the DOM.
        if (this.itemsContainer) this.itemsContainer.innerHTML = '';
        if (this.countElement) this.countElement.textContent = '0';
        this.updateItemsLabel(0);
        document.querySelectorAll('[data-cart-count]').forEach((el) => {
          el.textContent = '0';
          el.style.display = 'none';
        });
      } else if (domItemCount !== cart.items.length) {
        this.hideEmptyState();
        await this.refreshFromServer();
      }

      this.updateUpsellFromDOM();
    } finally {
      this.reconcileInFlight = false;
    }
  }

  open(trigger = null) {
    this.triggerElement = trigger || document.activeElement;
    this.sidecart.classList.add('is-open');
    this.sidecart.setAttribute('aria-hidden', 'false');
    document.getElementById('cart-toggle')?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    this.reconcileOnOpen();
    setTimeout(() => this.closeButton?.focus(), 100);
  }

  close() {
    this.sidecart.classList.remove('is-open');
    this.sidecart.setAttribute('aria-hidden', 'true');
    document.getElementById('cart-toggle')?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    this.triggerElement?.focus();
  }

  handleKeydown(e) {
    if (!this.sidecart.classList.contains('is-open')) return;
    

    if (e.key === 'Escape') {
      this.close();
      return;
    }

    if (e.key === 'Tab') {
      this.handleTabTrap(e);
    }
  }

  handleTabTrap(e) {
    const focusableElements = this.drawer.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');

    if (focusableElements.length === 0) return;
    

    const firstElement = focusableElements[0];
    const lastElement = focusableElements[focusableElements.length - 1];

    if (e.shiftKey && document.activeElement === firstElement) {
      e.preventDefault();
      lastElement.focus();
    } else if (!e.shiftKey && document.activeElement === lastElement) {
      e.preventDefault();
      firstElement.focus();
    }
  }

  showStockWarning(itemEl, actualQty) {
    const warning = itemEl?.querySelector('[data-stock-warning]');
    if (! warning) return;
    

    const msg = this.sidecart?.dataset.stockWarning || 'Only COUNT available';
    warning.textContent = msg.replace('COUNT', actualQty);
    warning.hidden = false;

    if (this.stockWarningTimeouts?.has(itemEl)) {
      clearTimeout(this.stockWarningTimeouts.get(itemEl));
    }
    if (!this.stockWarningTimeouts) 
      this.stockWarningTimeouts = new Map();
    

    const timeout = setTimeout(() => {
      warning.hidden = true;
      this.stockWarningTimeouts.delete(itemEl);
    }, 8000);
    this.stockWarningTimeouts.set(itemEl, timeout);
  }

  clearStockWarning(itemEl) {
    const warning = itemEl?.querySelector('[data-stock-warning]');
    if (warning) 
      warning.hidden = true;
    
  }

  showToast(msg) {
    const toast = document.createElement('div');
    toast.className = 'sidecart__toast';
    toast.textContent = msg;
    this.drawer?.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('sidecart__toast--visible'));
    setTimeout(() => {
      toast.classList.remove('sidecart__toast--visible');
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  async updateQuantity(key, quantity) {
    this.inFlightRequests ++;
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(
          {id: key, quantity}
        )
      });

      const cart = await response.json();
      this.inFlightRequests --;

      if (! response.ok) {
        await this.refreshFromServer();
        const itemEl = this.sidecart?.querySelector(`[data-sidecart-item][data-key="${key}"]`);
        const actualQty = parseInt(itemEl?.querySelector('[data-quantity]')?.value || '1', 10);
        this.showStockWarning(itemEl, actualQty);
        return;
      }

      const updatedItem = cart.items.find(i => i.key === key);
      const itemEl = this.sidecart?.querySelector(`[data-sidecart-item][data-key="${key}"]`);

      if (updatedItem && updatedItem.quantity<quantity) {
          const qtyEl = itemEl?.querySelector('[data-quantity]');
          const priceEl = itemEl?.querySelector('[data-price]');
          const comparePriceEl = itemEl?.querySelector('[data-compare-price]');
          const unitPrice = itemEl?.dataset.unitPrice ? parseInt(itemEl.dataset.unitPrice, 10) : 0;
          const compareUnitPrice = itemEl?.dataset.compareUnitPrice ? parseInt(itemEl.dataset.compareUnitPrice, 10) : 0;

          if (qtyEl) {
            qtyEl.value = updatedItem.quantity;
            qtyEl.defaultValue = updatedItem.quantity;
          }
          if (priceEl && unitPrice) priceEl.textContent = this.formatMoney(unitPrice * updatedItem.quantity);
          if (comparePriceEl && compareUnitPrice) comparePriceEl.textContent = this.formatMoney(compareUnitPrice * updatedItem.quantity);

          this.showStockWarning(itemEl, updatedItem.quantity);
        } else if (itemEl) {
          this.clearStockWarning(itemEl);
        }

        if (this.pendingMutations <= 1) {
          if (this.countElement) this.countElement.textContent = cart.item_count;
          this.updateItemsLabel(cart.item_count);
          document.querySelectorAll('[data-cart-count]').forEach(el => {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count > 0
          ? ''
          : 'none';
      }) 
      
      if (this.subtotalElement) {
        this.subtotalElement.textContent = this.formatMoney(cart.total_price);
      }
      this.updateShippingBar(cart.total_price);

      if (cart.item_count === 0) {
        this.showEmptyState();
      }

      document.dispatchEvent(new CustomEvent('cart:updated', {detail: {
          cart
        }}));
    }
  } catch (error) {
    this.inFlightRequests --;
    if (this.pendingMutations <= 1) {
      this.refreshFromServer();
    }
  }
}

async refreshFromServer() {
  try {
    const response = await fetch('/?section_id=sidecart', { cache: 'no-store' });
    const html = await response.text();
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const newContent = doc.querySelector('[data-sidecart-content]');
    const newFooter = doc.querySelector('[data-sidecart-footer]');
    if (newContent && this.content) {
      this.content.innerHTML = newContent.innerHTML;
    }
    if (newFooter && this.footer) {
      this.footer.innerHTML = newFooter.innerHTML;
    }
    const topShippingBar = this.sidecart?.querySelector('.sidecart__drawer > [data-shipping-bar]');
    const newTopShippingBar = doc.querySelector('.sidecart__drawer > [data-shipping-bar]');
    if (topShippingBar && newTopShippingBar) {
      topShippingBar.innerHTML = newTopShippingBar.innerHTML;
      topShippingBar.className = newTopShippingBar.className;
    }
    this.refreshElementRefs();
  } catch (e) {
    console.error('Failed to refresh sidecart:', e);
  }
}

async refresh(cartData) {
  const cart = cartData.cart || cartData;
  if (this.countElement) {
    this.countElement.textContent = cart.item_count;
  }
  this.updateItemsLabel(cart.item_count);

  document.querySelectorAll('[data-cart-count]').forEach(el => {
    el.textContent = cart.item_count;
    el.style.display = cart.item_count > 0
      ? ''
      : 'none';
