{%- liquid
  assign item_count = cart.item_count
  assign has_items = false
  if item_count > 0
    assign has_items = true
  endif
  assign enable_quick_cart = settings.enable_quick_cart
  assign show_dynamic_checkout = settings.show_dynamic_checkout

  assign shipping_bar_enabled = section.settings.enable_shipping_bar
  assign shipping_bar_position = section.settings.shipping_bar_position
  assign shipping_threshold_cents = section.settings.shipping_threshold | times: 100
  assign cart_total = cart.total_price
  assign shipping_remaining_cents = shipping_threshold_cents | minus: cart_total
  assign has_free_shipping = false
  if cart_total >= shipping_threshold_cents
    assign has_free_shipping = true
    assign shipping_remaining_cents = 0
  endif
  assign shipping_progress = cart_total | times: 100 | divided_by: shipping_threshold_cents
  if shipping_progress > 100
    assign shipping_progress = 100
  endif

  assign shipping_bar_preview = false
  if request.design_mode and shipping_bar_enabled and has_items == false
    assign shipping_bar_preview = true
    assign shipping_remaining_cents = shipping_threshold_cents | times: 40 | divided_by: 100
    assign shipping_progress = 60
  endif
-%}

{% if enable_quick_cart %}
  <div
    class="sidecart"
    id="sidecart"
    aria-hidden="true"
    data-sidecart
    data-money-format="{{ shop.money_format | escape }}"
    data-item-singular="{{ 'sidecart.item' | t | escape }}"
    data-item-plural="{{ 'sidecart.items' | t | escape }}"
    data-stock-warning="{{ 'sidecart.stock_warning' | t | escape }}"
    style="--sidecart-bg: {{ section.settings.background_color }}; --sidecart-text: {{ section.settings.text_color }};"
    {% if shipping_bar_enabled %}
    data-shipping-bar-enabled
    data-shipping-threshold="{{ shipping_threshold_cents }}"
    data-shipping-progress-msg="{{ section.settings.shipping_progress_message | escape }}"
    data-shipping-success-msg="{{ section.settings.shipping_success_message | escape }}"
    {% endif %}>

    <div class="sidecart__overlay" id="sidecart-overlay"></div>

    <div
      class="sidecart__drawer"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sidecart.title' | t }}">

      <div class="sidecart__header">
        <h2 class="sidecart__title">
          <span
            class="sidecart__count"
            data-sidecart-count
            aria-live="polite">{{ item_count }}</span>
          <span data-sidecart-items-label>
            {% if item_count == 1 %}
              {{ 'sidecart.item' | t }}
            {% else %}
              {{ 'sidecart.items' | t }}{% endif %}
          </span>
        </h2>
        <button
          type="button"
          class="sidecart__close"
          aria-label="{{ 'sidecart.close' | t }}"
          id="sidecart-close">
          <svg
            aria-hidden="true"
            focusable="false"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none">
            <path
              d="M18 6L6 18M6 6L18 18"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round" />
          </svg>
        </button>
      </div>

      {% if shipping_bar_enabled and shipping_bar_position == 'top' %}
        <div
          class="sidecart__shipping-bar{% unless has_items or shipping_bar_preview %} sidecart__shipping-bar--hidden{% endunless %}"
          data-shipping-bar
          style="--shipping-bar-fill: {{ section.settings.shipping_bar_fill_color }}; --shipping-bar-track: {{ section.settings.shipping_bar_track_color }}; --shipping-bar-text: {{ section.settings.shipping_bar_text_color | default: section.settings.text_color }};">
          <p class="sidecart__shipping-bar-text" data-shipping-bar-text>
            {%- if has_free_shipping -%}
              {{ section.settings.shipping_success_message }}
            {%- else -%}
              {%- assign shipping_amount_display = shipping_remaining_cents | money -%}
              {{ section.settings.shipping_progress_message | replace: '[amount]', shipping_amount_display }}
            {%- endif -%}
          </p>
          <div class="sidecart__shipping-bar-track">
            <div
              class="sidecart__shipping-bar-fill"
              data-shipping-bar-fill
              style="width: {{ shipping_progress }}%">
              {% if section.settings.shipping_bar_icon != blank %}
                <span class="sidecart__shipping-bar-icon" aria-hidden="true"
                  style="--shipping-bar-icon-url: url('{{ section.settings.shipping_bar_icon | image_url: width: 56 }}'); --shipping-bar-icon-color: {{ section.settings.shipping_bar_icon_color | default: section.settings.shipping_bar_fill_color }};">
                  <span class="sidecart__shipping-bar-icon-img"></span>
                </span>
              {% endif %}
    </div>
  </div>
</div>{% render 'promo-banner', location: 'sidecart-top' %}{% endif %}<div class="sidecart__content" data-sidecart-content>
<ul
  class="sidecart__items{% unless has_items %} sidecart__items--hidden{% endunless %}"
  role="list"
  data-sidecart-items>
  {%- comment -%}
    A Buy-X-Get-Y discount splits one variant into several line items at
    different prices. Group cart.items by variant_id + properties so the same
    product is shown as ONE merged card. The signature MUST match the JS
    signatureOf() in this section's script: variant_id then `@first=last` per
    property, in cart order. A bracket wrapper guards against prefix collisions.
  {%- endcomment -%}
  {%- assign rendered_sigs = '' -%}
  {%- for item in cart.items -%}
    {%- capture raw_sig -%}{{ item.variant_id }}{%- for p in item.properties -%}@{{ p.first }}={{ p.last }}{%- endfor -%}{%- if item.selling_plan_allocation -%}~sp{{ item.selling_plan_allocation.selling_plan.id }}{%- endif -%}{%- endcapture -%}
    {%- assign sig_token = '[' | append: raw_sig | append: ']' -%}
    {%- unless rendered_sigs contains sig_token -%}
      {%- assign rendered_sigs = rendered_sigs | append: sig_token -%}
      {%- liquid
        assign group_qty = 0
        assign group_final = 0
        assign group_original = 0
        assign group_lines = 0
        for it in cart.items
          capture it_sig
            echo it.variant_id
            for p in it.properties
              echo '@'
              echo p.first
              echo '='
              echo p.last
            endfor
            if it.selling_plan_allocation
              echo '~sp'
              echo it.selling_plan_allocation.selling_plan.id
            endif
          endcapture
          if it_sig == raw_sig
            assign group_qty = group_qty | plus: it.quantity
            assign group_final = group_final | plus: it.final_line_price
            assign group_original = group_original | plus: it.original_line_price
            assign group_lines = group_lines | plus: 1
          endif
        endfor
      -%}
      {%- render 'sidecart-item',
        item: item,
        group_quantity: group_qty,
        group_final_line_price: group_final,
        group_original_line_price: group_original,
        group_line_count: group_lines,
        group_signature: raw_sig -%}
    {%- endunless -%}
  {%- endfor -%}
</ul>
<div class="sidecart__empty{% if has_items %} sidecart__empty--hidden{% endif %}" data-sidecart-empty>
  <h3 class="sidecart__empty-title">{{ section.settings.empty_title }}</h3>
  <p class="sidecart__empty-message">{{ section.settings.empty_message }}</p>
  <a href="{{ routes.all_products_collection_url }}" class="sidecart__continue-btn">
    {{ section.settings.continue_button_text }}
  </a>
</div></div>{% render 'sidecart-upsell', enabled: section.settings.enable_upsell, heading: section.settings.upsell_heading, product_1: section.settings.upsell_product_1, product_2: section.settings.upsell_product_2, exclude_collection: section.settings.upsell_exclude_collection %}<div class="sidecart__footer{% unless has_items or shipping_bar_preview %} sidecart__footer--hidden{% endunless %}" data-sidecart-footer>
{% if shipping_bar_enabled and shipping_bar_position == 'bottom' %}
  <div
    class="sidecart__shipping-bar"
    data-shipping-bar
    style="--shipping-bar-fill: {{ section.settings.shipping_bar_fill_color }}; --shipping-bar-track: {{ section.settings.shipping_bar_track_color }}; --shipping-bar-text: {{ section.settings.shipping_bar_text_color | default: section.settings.text_color }};">
    <p class="sidecart__shipping-bar-text" data-shipping-bar-text>
      {%- if has_free_shipping -%}
        {{ section.settings.shipping_success_message }}
      {%- else -%}
        {%- assign shipping_amount_display = shipping_remaining_cents | money -%}
        {{ section.settings.shipping_progress_message | replace: '[amount]', shipping_amount_display }}
      {%- endif -%}
    </p>
    <div class="sidecart__shipping-bar-track">
      <div
        class="sidecart__shipping-bar-fill"
        data-shipping-bar-fill
        style="width: {{ shipping_progress }}%">
        {% if section.settings.shipping_bar_icon != blank %}
          <span class="sidecart__shipping-bar-icon" aria-hidden="true">
            <img src="{{ section.settings.shipping_bar_icon | image_url: width: 40 }}" alt="" width="20" height="20" loading="lazy">
          </span>
        {% endif %}
      </div>
    </div>
  </div>
  {% render 'promo-banner', location: 'sidecart-bottom' %}
{% endif %}

<div class="sidecart__subtotal-row">
  <span class="sidecart__subtotal-label">{{ 'sidecart.subtotal' | t }}</span>
  <div class="sidecart__subtotal-value-wrapper">
    <span
      class="sidecart__subtotal-value"
      data-sidecart-subtotal
      aria-live="polite">{{ cart.total_price | money }}</span>
    <span class="sidecart__shipping-note">{{ 'sidecart.shipping_note' | t }}</span>
  </div>
</div>

<div class="sidecart__actions sidecart__actions--single">
  <a href="/checkout" class="sidecart__btn sidecart__btn--primary">
    {{ 'sidecart.checkout' | t }}
  </a>
</div>

{% if show_dynamic_checkout %}
  <div class="sidecart__dynamic-checkout" data-sidecart-dynamic-checkout>
    {{ content_for_additional_checkout_buttons }}
  </div>
{% endif %}</div></div></div>{% endif %}{% stylesheet %}
.sidecart {
  --sidecart-width: 615px;
  /* --sidecart-bg and --sidecart-text set via inline style from section settings */
  --sidecart-border: rgba(62, 32, 39, 0.1);

  position: fixed;
  inset: 0;
  z-index: 300;
  visibility: hidden;
  pointer-events: none;
  transition: visibility 0s 0.3s;
}

.sidecart.is-open {
  visibility: visible;
  pointer-events: auto;
  transition: visibility 0s 0s;
}

.sidecart__overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
  cursor: pointer;
}

.sidecart.is-open .sidecart__overlay {
  opacity: 1;
}

.sidecart__drawer {
  position: absolute;
  top: 0;
  right: 0;
  width: var(--sidecart-width);
  max-width: 100%;
  height: 100%;
  background-color: var(--sidecart-bg);
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.sidecart.is-open .sidecart__drawer {
  transform: translateX(0);
}

.sidecart__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px;
  border-bottom: 1px solid var(--sidecart-border);
  flex-shrink: 0;
}

.sidecart__title {
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 16px;
  letter-spacing: -0.16px;
  text-transform: uppercase;
  color: var(--sidecart-text);
  margin: 0;
}

.sidecart__count {
  margin-right: 4px;
}

.sidecart__close {
  color: var(--sidecart-text);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.sidecart__close:hover {
  opacity: 0.7;
}

.sidecart__close:focus-visible {
  outline: 2px solid var(--sidecart-text);
  outline-offset: 4px;
}

.sidecart__content {
  flex: 1;
  overflow-y: auto;
  padding: 15px 20px;
}

.sidecart__items {
  list-style: none;
  /* Pull the list up by one item's top padding so the first VISIBLE card sits
     the right distance below the content top WITHOUT relying on :first-child —
     an optimistically-hidden (display:none) item still counts as :first-child,
     which would otherwise leave the first visible card with extra top padding
     until the reconcile removes the hidden node (a visible layout snap). */
  margin: -15px 0 0;
  padding: 0;
}

.sidecart__items--hidden {
  display: none;
}

.sidecart-item {
  position: relative;
  display: flex;
  gap: 20px;
  padding: 15px 0;
  border-bottom: 1px solid var(--sidecart-border);
}

.sidecart-item__remove {
  position: absolute;
  top: 15px;
  right: 0;
  background: transparent;
  border: none;
  cursor: pointer;
  font-family: var(--font-jokker);
  font-size: 10px;
  color: var(--sidecart-text);
  text-decoration: none;
  transition: text-decoration 0.15s ease;
}

.sidecart-item__remove:hover {
  text-decoration: underline;
}

.sidecart-item__image-link {
  flex-shrink: 0;
  display: block;
  width: 150px;
  height: 194px;
  overflow: hidden;
  background-color: var(--sidecart-bg);
}

.sidecart-item__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.sidecart-item__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--sidecart-bg);
}

.sidecart-item__placeholder-svg {
  width: 60%;
  height: 60%;
  opacity: 0.3;
}

.sidecart-item__details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  padding: 10px 0;
}

.sidecart-item__info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sidecart-item__title {
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 14px;
  letter-spacing: -0.14px;
  text-transform: uppercase;
  color: var(--sidecart-text);
  margin: 0;
}

.sidecart-item__title a {
  color: inherit;
  text-decoration: none;
}

.sidecart-item__title a:hover {
  text-decoration: underline;
}

.sidecart-item__variant {
  font-family: var(--font-manrope);
  font-size: 12px;
  color: var(--sidecart-text);
  opacity: 0.7;
  margin: 0;
}

.sidecart-item__properties {
  list-style: none;
  margin: 4px 0 0;
  padding: 0;
}

.sidecart-item__property {
  font-family: var(--font-manrope);
  font-size: 11px;
  color: var(--sidecart-text);
  opacity: 0.7;
  line-height: 1.4;
}

.sidecart-item__bundle-bottles {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 4px;
  box-sizing: border-box;
}

.sidecart-item__bundle-bottle {
  width: auto;
  max-width: 45%;
  height: auto;
  max-height: 100%;
  object-fit: contain;
  object-position: center;
  margin: 0 -10px;
}

.sidecart-item__bundle-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.sidecart-item__bundle-scent {
  font-family: var(--font-jokker);
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: none;
  color: var(--sidecart-text);
  opacity: 0.75;
  line-height: 1.5;
}

.sidecart-item__description {
  font-family: var(--font-jokker);
  font-size: 14px;
  font-weight: 400;
  line-height: 130%;
  color: var(--sidecart-text);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sidecart-item__controls {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 15px;
  margin-top: 16px;
  padding-top: 4px;
}

.sidecart-item__stock-warning {
  width: 100%;
  font-family: var(--font-jokker);
  font-size: 12px;
  font-weight: 500;
  color: #c44;
  margin: 0;
}

.sidecart-item__quantity {
  display: flex;
  align-items: center;
  border: 1px solid var(--sidecart-border);
}

.sidecart-item__qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--sidecart-text);
  transition: background-color 0.15s ease;
}

.sidecart-item__qty-btn:hover {
  background-color: color-mix(in srgb, var(--sidecart-text) 10%, var(--sidecart-bg));
}

.sidecart-item__qty-btn:active {
  opacity: 0.8;
}

.sidecart-item__qty-btn:focus-visible {
  outline: 2px solid var(--sidecart-text);
  outline-offset: -2px;
}

.sidecart-item__qty-input {
  font-family: var(--font-manrope);
  font-size: 14px;
  color: var(--sidecart-text);
  width: 40px;
  text-align: center;
  border: none;
  background: transparent;
  padding: 0;
  -moz-appearance: textfield;
}

.sidecart-item__qty-input::-webkit-outer-spin-button,
.sidecart-item__qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.sidecart-item__qty-input:focus {
  outline: 2px solid var(--sidecart-text);
  outline-offset: 2px;
}

.sidecart-item__price {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.sidecart-item__compare-price {
  font-family: var(--font-sweet-sans);
  font-size: 14px;
  font-weight: 400;
  letter-spacing: -0.14px;
  text-transform: uppercase;
  text-decoration: line-through;
  color: var(--sidecart-text);
}

.sidecart-item__current-price {
  font-family: var(--font-sweet-sans);
  font-weight: 400;
  font-size: 18px;
  letter-spacing: -0.18px;
  text-transform: uppercase;
  color: var(--sidecart-text);
}

.sidecart-item__current-price--sale {
  color: #E26046;
}

.sidecart__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 60px 20px;
  height: 100%;
}

.sidecart__empty--hidden {
  display: none;
}

.sidecart.is-loading .sidecart__items {
  pointer-events: none;
}

.sidecart.is-loading .sidecart__empty {
  display: none;
}

.sidecart.is-loading .sidecart__content {
  position: relative;
  min-height: 200px;
}

.sidecart.is-loading .sidecart__content::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 32px;
  height: 32px;
  margin: -16px 0 0 -16px;
  border: 2px solid var(--sidecart-border);
  border-top-color: var(--sidecart-text);
  border-radius: 50%;
  animation: sidecart-spin 0.8s linear infinite;
}

@keyframes sidecart-spin {
  to {
    transform: rotate(360deg);
  }
}

.sidecart__empty-title {
  font-family: var(--font-jokker);
  font-size: 24px;
  font-weight: 400;
  color: var(--sidecart-text);
  margin: 0 0 8px;
}

.sidecart__empty-message {
  font-family: var(--font-manrope);
  font-size: 14px;
  color: var(--sidecart-text);
  opacity: 0.7;
  margin: 0 0 24px;
}

.sidecart__continue-btn {
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: -0.12px;
  text-transform: uppercase;
  color: var(--sidecart-bg);
  background-color: var(--sidecart-text);
  border: none;
  padding: 14px 28px;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.sidecart__continue-btn:hover {
  opacity: 0.85;
}

.sidecart__shipping-bar {
  padding: 14px 20px;
  border-bottom: 1px solid var(--sidecart-border);
  flex-shrink: 0;
  color: var(--shipping-bar-text, var(--sidecart-text));
}

.sidecart__shipping-bar--hidden {
  display: none;
}

.sidecart__footer .sidecart__shipping-bar {
  border-bottom: none;
  border-top: none;
  padding: 0 0 14px;
}

.sidecart__shipping-bar-text {
  font-family: var(--font-sweet-sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: -0.13px;
  margin: 0 0 14px;
  text-align: center;
  color: var(--shipping-bar-text, var(--sidecart-text));
}

.sidecart__shipping-bar-track {
  width: 100%;
  height: 6px;
  border-radius: 3px;
  background-color: var(--shipping-bar-track, rgba(62, 32, 39, 0.15));
  overflow: visible;
  position: relative;
}

.sidecart__shipping-bar-fill {
  height: 100%;
  border-radius: 3px;
  background-color: var(--shipping-bar-fill, #3E2027);
  transition: width 0.3s ease;
  min-width: 0;
  max-width: calc(100% - 22px);
  position: relative;
}

.sidecart__shipping-bar-icon {
  position: absolute;
  right: -22px;
  top: 50%;
  transform: translateY(-57%);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
}

.sidecart__shipping-bar-icon img,
.sidecart__shipping-bar-icon svg {
  display: block;
  width: 30px;
  height: 30px;
  object-fit: contain;
}

.sidecart__shipping-bar-icon-img {
  display: block;
  width: 30px;
  height: 30px;
  background-color: var(--shipping-bar-icon-color, var(--shipping-bar-fill, #3E2027));
  -webkit-mask-image: var(--shipping-bar-icon-url);
  mask-image: var(--shipping-bar-icon-url);
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.sidecart__footer {
  padding: 20px;
  border-top: 1px solid var(--sidecart-border);
  flex-shrink: 0;
}

.sidecart__footer--hidden {
  display: none;
}

.sidecart__subtotal-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 14px;
}

.sidecart__subtotal-label {
  font-family: var(--font-sweet-sans);
  font-weight: 500;
  font-size: 16px;
  letter-spacing: -0.16px;
  text-transform: uppercase;
  color: var(--sidecart-text);
}

.sidecart__subtotal-value-wrapper {
  text-align: right;
}

.sidecart__subtotal-value {
  font-family: var(--font-sweet-sans);
  font-weight: 400;
  font-size: 18px;
  letter-spacing: -0.18px;
  text-transform: uppercase;
  color: var(--sidecart-text);
  display: block;
}

.sidecart__shipping-note {
  font-family: var(--font-jokker);
  font-size: 10px;
  font-weight: 400;
  color: var(--sidecart-text);
  display: block;
