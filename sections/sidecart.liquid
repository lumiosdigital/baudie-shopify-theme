}{% endstylesheet %}{% javascript %}
class Sidecart {
  constructor() {
    this.sidecart = document.getElementById('sidecart');
    if (!this.sidecart) return;

    this.overlay = document.getElementById('sidecart-overlay');
    this.closeButton = document.getElementById('sidecart-close');
    this.drawer = this.sidecart.querySelector('.sidecart__drawer');

    this.itemSingular = this.sidecart.dataset.itemSingular || 'item';
    this.itemPlural = this.sidecart.dataset.itemPlural || 'items';

    this.shippingBarEnabled = this.sidecart.hasAttribute('data-shipping-bar-enabled');
    this.shippingThreshold = parseInt(this.sidecart.dataset.shippingThreshold || '0', 10);
    this.shippingProgressMsg = this.sidecart.dataset.shippingProgressMsg || '';
    this.shippingSuccessMsg = this.sidecart.dataset.shippingSuccessMsg || '';

    this.triggerElement = null;
    this.stockWarningTimeouts = new Map();

    // --- Cart mutation model -------------------------------------------------
    // Shopify's cart API is not concurrency-safe, and the conditional Buy-X-Get-Y
    // upsell discount (a) splits one variant across several line items at
    // different prices, (b) re-keys every line on any cart change, and (c) makes
    // line prices non-linear. So we never trust line keys or unit*qty math:
    //   - every cart write runs through ONE serialized FIFO chain (no concurrency),
    //   - each write re-reads /cart.js and targets lines by their LIVE 1-based
    //     `line` index, resolved via a variant+properties signature, and
    //   - once the chain drains we re-render the whole drawer from the server.
    // Quantity changes optimistically (instant), but money always reconciles
    // from the authoritative cart because a discount makes it non-linear.
    this.chain = Promise.resolve();
    this.pendingTargets = new Map(); // signature -> desired total quantity
    this.flushTimer = null;
    this.busy = 0; // >0 while any queued job is running
    this.dirty = false; // a real mutation happened since the last render
    this.generation = 0; // bumped on every optimistic change; lets a slow
    // reconcile detect that newer input arrived and skip clobbering it
    this.clamped = new Map(); // signature -> achieved qty when an increase was stock-capped
    this.lastCart = null; // most recent authoritative cart (from a mutation/fetch)
    this.needsStructureRender = false; // a queued op changes the set of cards
    // (add / external update / open) and needs the Liquid section re-render;
    // plain qty/remove only needs a fast in-place money update.
    this.renderRetries = 0; // bounded retries when a structure render's fetch fails

    this.cacheRefs();
    this.bindEvents();
    this.initCartListeners();
  }

  cacheRefs() {
    this.content = this.sidecart.querySelector('[data-sidecart-content]');
    this.itemsContainer = this.sidecart.querySelector('[data-sidecart-items]');
    this.footer = this.sidecart.querySelector('[data-sidecart-footer]');
    this.countElement = this.sidecart.querySelector('[data-sidecart-count]');
    this.itemsLabelElement = this.sidecart.querySelector('[data-sidecart-items-label]');
    this.subtotalElement = this.sidecart.querySelector('[data-sidecart-subtotal]');
    this.emptyElement = this.sidecart.querySelector('[data-sidecart-empty]');
    this.shippingBar = this.sidecart.querySelector('[data-shipping-bar]');
    this.shippingBarText = this.sidecart.querySelector('[data-shipping-bar-text]');
    this.shippingBarFill = this.sidecart.querySelector('[data-shipping-bar-fill]');
  }

  // Kept for backwards-compatibility with any external callers.
  refreshElementRefs() {
    this.cacheRefs();
  }

  // ---- Signature + discount helpers --------------------------------------
  // signatureOfLine MUST match the Liquid grouping in this section:
  // variant_id, then `@first=last` for each property, in cart order.
  //
  // Liquid exposes line-item property keys/values HTML-escaped (e.g. a bundle's
  // "_bundle_selection" value "A <> B" comes through as "A &lt;&gt; B"), and the
  // section writes them into data-properties-signature. /cart.js returns the
  // SAME values raw ("A <> B"). To make both signatures identical we escape the
  // raw API values here the same way Liquid does — otherwise bundle lines (the
  // only ones with <,>,& in a property) never match their card and can't be
  // removed or have their price updated in place.
  htmlEscape(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  signatureOfLine(line) {
    let sig = String(line.variant_id);
    const props = line.properties;
    if (props && typeof props === 'object') {
      Object.keys(props).forEach((k) => {
        sig += '@' + this.htmlEscape(k) + '=' + this.htmlEscape(props[k]);
      });
    }
    if (line.selling_plan_allocation && line.selling_plan_allocation.selling_plan) {
      sig += '~sp' + line.selling_plan_allocation.selling_plan.id;
    }
    return sig;
  }

  isDiscountedLine(line) {
    if (line.total_discount && line.total_discount > 0) return true;
    if (Array.isArray(line.line_level_discount_allocations) && line.line_level_discount_allocations.length > 0) return true;
    const final = typeof line.final_price === 'number' ? line.final_price : line.price;
    const original = typeof line.original_price === 'number' ? line.original_price : line.price;
    return final < original;
  }

  // ---- Event wiring -------------------------------------------------------
  bindEvents() {
    this.closeButton?.addEventListener('click', () => this.close());
    this.overlay?.addEventListener('click', () => this.close());
    document.addEventListener('keydown', (e) => this.handleKeydown(e));

    this.sidecart.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      const item = btn.closest('[data-sidecart-item]');
      if (!item) return;
      this.handleAction(btn.dataset.action, item);
    });

    this.sidecart.addEventListener('change', (e) => {
      const input = e.target.closest('[data-quantity]');
      if (!input) return;
      const item = input.closest('[data-sidecart-item]');
      if (!item) return;
      let value = parseInt(input.value || '0', 10);
      if (isNaN(value) || value < 0) value = 0;
      this.setItemQuantity(item, value);
    });
  }

  handleAction(action, item) {
    const input = item.querySelector('[data-quantity]');
    const currentQty = parseInt(input?.value || '1', 10);
    const inventory = parseInt(item.dataset.inventory || '99999', 10);
    const inventoryPolicy = item.dataset.inventoryPolicy || 'deny';

    if (action === 'increase') {
      if (inventoryPolicy === 'deny' && currentQty >= inventory) {
        this.showStockWarning(item, inventory);
        return;
      }
      this.setItemQuantity(item, currentQty + 1);
    } else if (action === 'decrease') {
      this.setItemQuantity(item, currentQty > 1 ? currentQty - 1 : 0);
    } else if (action === 'remove') {
      this.setItemQuantity(item, 0);
    }
  }

  // Optimistic: reflect the new quantity instantly and queue the authoritative
  // write. Per-line price + subtotal are intentionally NOT recomputed here
  // (a Buy-X-Get-Y discount makes them non-linear); they reconcile from the
  // server when the queue drains. The optimistic line price + subtotal use a
  // simple unit*qty estimate (exact when no discount touches the line); the
  // authoritative reconcile corrects any non-linear discount case a moment later.
  setItemQuantity(item, newQty) {
    const signature = item.dataset.propertiesSignature || '';
    const input = item.querySelector('[data-quantity]');
    // defaultValue tracks the last known quantity; input.value may already hold
    // the freshly typed value by the time a `change` event fires.
    const oldQty = parseInt((input && (input.defaultValue || input.value)) || '1', 10);
    const unitPrice = parseInt(item.dataset.unitPrice || '0', 10);

    this.dirty = true;
    this.generation++;

    if (newQty <= 0) {
      // Move focus out before hiding, so a keyboard/screen-reader user who
      // activated Remove isn't dumped onto document.body.
      if (item.contains(document.activeElement)) {
        const others = Array.from(
          this.sidecart.querySelectorAll('[data-sidecart-item]:not([aria-hidden="true"])')
        ).filter((el) => el !== item);
        const focusTarget = (others[0] && others[0].querySelector('[data-action="remove"]')) || this.closeButton;
        focusTarget?.focus();
      }
      item.setAttribute('aria-hidden', 'true');
      item.style.display = 'none';
      this.adjustCountBadge(-oldQty);
      this.adjustSubtotalOptimistic(-unitPrice * oldQty);
      this.pendingTargets.set(signature, 0);
    } else {
      if (input) {
        input.value = newQty;
        input.defaultValue = String(newQty);
      }
      // Scale BOTH the current and the strike-through price together so a
      // discounted line never shows a nonsensical pair. Exact for full-price /
      // regular-sale lines; a close estimate for Buy-X-Get-Y, corrected by the
      // reconcile a moment later.
      const originalUnit = parseInt(item.dataset.originalUnit || String(unitPrice), 10);
      if (unitPrice) this.renderCardPrice(item, newQty, unitPrice * newQty, originalUnit * newQty);
      this.adjustCountBadge(newQty - oldQty);
      this.adjustSubtotalOptimistic(unitPrice * (newQty - oldQty));
      this.pendingTargets.set(signature, newQty);
    }

    this.scheduleFlush();
    this.updateUpsellFromDOM();
  }

  // Optimistically nudge the subtotal + shipping bar by a cent delta, tracking
  // the value in cents to avoid money-string parse/format drift across rapid
  // clicks. The authoritative cart total resets this on the next reconcile.
  adjustSubtotalOptimistic(deltaCents) {
    if (!deltaCents) return;
    if (typeof this.subtotalCents !== 'number') {
      this.subtotalCents = this.parseMoney(this.subtotalElement && this.subtotalElement.textContent);
    }
    this.subtotalCents = Math.max(0, this.subtotalCents + deltaCents);
    if (this.subtotalElement) this.subtotalElement.textContent = this.formatMoney(this.subtotalCents);
    this.updateShippingBar(this.subtotalCents);
  }

  parseMoney(str) {
    const cleaned = (str || '').replace(/[^0-9.,]/g, '').replace(',', '.');
    return Math.round(parseFloat(cleaned) * 100) || 0;
  }

  scheduleFlush() {
    if (this.flushTimer) clearTimeout(this.flushTimer);
    // Short debounce: long enough to coalesce a burst of rapid +/- clicks into
    // one server write, short enough that prices feel responsive.
    this.flushTimer = setTimeout(() => this.flush(), 120);
  }

  flush() {
    if (this.pendingTargets.size === 0) return;
    const targets = new Map(this.pendingTargets);
    this.pendingTargets.clear();
    this.enqueue(async () => {
      for (const [signature, qty] of targets) {
        // A newer action for this signature has already been re-queued; skip
        // this stale one and let the newer target win.
        if (this.pendingTargets.has(signature)) continue;
        try {
          await this.reconcileGroupTo(signature, qty);
        } catch (err) {
          console.error('Sidecart group reconcile failed:', err);
        }
      }
    });
  }

  // Mark that the set of cards may have changed (add / external update / open),
  // so the next drain does a full Liquid re-render. Bumping the generation also
  // invalidates any reconcileRender already in flight (which never bumps it
  // itself), so it bails instead of finishing against the stale pre-change cart
  // and clearing this flag out from under us.
  requestStructureRender() {
    this.needsStructureRender = true;
    this.generation++;
  }

  // Run a job on the serialized chain. The chain itself is kept alive even if a
  // job rejects, but the returned promise rejects so callers (e.g. add-to-cart)
  // can surface errors. A single authoritative re-render runs once the queue
  // fully drains.
  enqueue(job) {
    this.busy++;
    const run = this.chain.then(() => job());
    this.chain = run
      .catch((err) => {
        console.error('Sidecart mutation failed:', err);
      })
      .finally(() => {
        this.busy--;
        if (this.busy === 0 && this.pendingTargets.size === 0) {
          // Add / external update / open changes the set of cards -> full Liquid
          // re-render. Plain qty/remove -> fast in-place money update (no extra
          // network: the change.js response cart is already cached in lastCart).
          if (this.needsStructureRender) return this.reconcileRender();
          return this.applyCartMoney(this.lastCart);
        }
      });
    return run;
  }

  async fetchCart() {
    const res = await fetch('/cart.js', { cache: 'no-store' });
    const cart = await res.json();
    this.lastCart = cart;
    return cart;
  }

  async changeLine(line, quantity) {
    const res = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ line, quantity })
    });
    if (!res.ok) throw new Error('cart/change failed: ' + res.status);
    // change.js returns the full authoritative cart — cache it so we can render
    // money in place without another /cart.js round-trip.
    const cart = await res.json();
    this.lastCart = cart;
    return cart;
  }

  // Drive a variant+properties group to a target TOTAL quantity. Re-reads the
  // cart each step so it always uses fresh line indices (which shift as the
  // discount re-allocates). Reducing prefers full-price lines so the customer
  // keeps the discounted unit as long as possible.
  //
  // The travel is DIRECTION-LOCKED (only ever increase, or only ever decrease)
  // so a discount that re-allocates on a step can never push us into an
  // increase/decrease oscillation. If the discount makes the exact target
  // unreachable (e.g. a "buy 2 get 1" deal where the in-between total is forced
  // by the rule) or stock caps an increase, we stop at the nearest achievable
  // total instead of thrashing, and flag a stock clamp so the UI can warn.
  async reconcileGroupTo(signature, target) {
    let direction = 0; // -1 decreasing, +1 increasing (set on first read)
    const seen = new Set();
    // Fetch the authoritative cart once to resolve the live line index. After
    // that, each /cart/change.js response IS the next authoritative cart, so we
    // reuse it instead of re-fetching — saving a round-trip on every step.
    let cart = await this.fetchCart();
    for (let guard = 0; guard < 30; guard++) {
      const lines = (cart.items || [])
        .map((line, idx) => ({ line, index: idx + 1 }))
        .filter((x) => this.signatureOfLine(x.line) === signature);

      if (lines.length === 0) return;
      const total = lines.reduce((s, x) => s + x.line.quantity, 0);
      if (total === target) return;

      if (direction === 0) direction = target > total ? 1 : -1;

      // Moved past the target in our travel direction, or revisited a total
      // (no further progress possible) -> accept the nearest achievable total.
      if (direction > 0 && total > target) return;
      if (direction < 0 && total < target) return;
      if (seen.has(total)) {
        if (direction > 0 && total < target) this.clamped.set(signature, total);
        return;
      }
      seen.add(total);

      if (target <= 0) {
        cart = await this.changeLine(lines[0].index, 0);
        continue;
      }

      if (direction > 0) {
        const full = lines.find((x) => !this.isDiscountedLine(x.line)) || lines[0];
        cart = await this.changeLine(full.index, full.line.quantity + (target - total));
      } else {
        const ordered = [
          ...lines.filter((x) => !this.isDiscountedLine(x.line)),
          ...lines.filter((x) => this.isDiscountedLine(x.line))
        ];
        const tgt = ordered[0];
        const reduce = Math.min(total - target, tgt.line.quantity);
        cart = await this.changeLine(tgt.index, tgt.line.quantity - reduce);
      }
    }
  }

  // ---- Authoritative re-render -------------------------------------------
  async reconcileRender() {
    // Snapshot the optimistic-change counter. If the user interacts again
    // during our (network-latency) fetch window, a newer change has been made
    // optimistically and queued; replacing innerHTML now would clobber it back
    // to pre-click state. Bail and let the queued change's own reconcile render.
    const gen = this.generation;
    let cart;
    let html;
    try {
      const cartPromise = this.fetchCart();
      const htmlPromise = fetch('/?section_id=sidecart', { cache: 'no-store' }).then((r) => r.text());
      cart = await cartPromise;
      // Update only the count badge early (it lives in the header, which the
      // section render does NOT replace) so it responds the moment the cart
      // lands. Subtotal/shipping/cards all come from the section markup below,
      // so writing them here would be wasted and could show a one-frame
      // count/cards mismatch.
      if (this.generation === gen) this.applyCartCount(cart);
      html = await htmlPromise;
    } catch (e) {
      this.markContentBusy(false);
      // Leave needsStructureRender set and retry shortly (bounded) so a transient
      // fetch failure can't strand a just-added card in the open drawer.
      if (this.needsStructureRender && this.renderRetries < 3) {
        this.renderRetries++;
        setTimeout(() => {
          if (this.needsStructureRender) this.enqueue(async () => {});
        }, 800);
      }
      return;
    }

    if (this.generation !== gen) {
      // Newer optimistic input arrived; leave needsStructureRender set so the
      // queued change's drain retries this render and a newly-added card still
      // appears once interaction settles.
      this.markContentBusy(false);
      return;
    }

    const doc = new DOMParser().parseFromString(html, 'text/html');
    const newContent = doc.querySelector('[data-sidecart-content]');
    const newFooter = doc.querySelector('[data-sidecart-footer]');
    if (newContent && this.content) this.content.innerHTML = newContent.innerHTML;
    if (newFooter && this.footer) this.footer.innerHTML = newFooter.innerHTML;

    const topBar = this.sidecart.querySelector('.sidecart__drawer > [data-shipping-bar]');
    const newTopBar = doc.querySelector('.sidecart__drawer > [data-shipping-bar]');
    if (topBar && newTopBar) {
      topBar.innerHTML = newTopBar.innerHTML;
      topBar.className = newTopBar.className;
    }

    this.cacheRefs();
    this.applyCartTotals(cart);
    this.applyUpsellVisibility((cart.items || []).map((i) => String(i.product_id)));
    this.surfaceClamps();
    this.needsStructureRender = false;
    this.renderRetries = 0;
    this.markContentBusy(false);

    // Notify other components (e.g. the main cart page) of real cart changes.
    // Tagged fromSidecart so our own listener ignores it, and only fired when a
    // mutation actually happened (never on a plain open/reconcile).
    if (this.dirty) {
      this.dirty = false;
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart, fromSidecart: true } }));
    }
  }

  // Warn on any group whose increase the server could not fully honour (stock
  // capped), recorded by reconcileGroupTo. Runs after the cards are re-rendered.
  surfaceClamps() {
    if (this.clamped.size === 0) return;
    const esc = (s) => (window.CSS && CSS.escape ? CSS.escape(s) : s);
    this.clamped.forEach((qty, signature) => {
      let card = null;
      try {
        card = this.sidecart.querySelector('[data-sidecart-item][data-properties-signature="' + esc(signature) + '"]');
      } catch (e) {
        card = null;
      }
      if (card) this.showStockWarning(card, qty);
    });
    this.clamped.clear();
  }

  // Fast path for qty/remove: update money + quantities in place from the
  // authoritative cart the mutation already returned — no /cart.js fetch and no
  // Liquid section re-render. A qty change never creates a NEW card (a discount
  // split merges into the same signature group), so only updates and removals
  // are needed here; new cards go through reconcileRender instead.
  applyCartMoney(cart) {
    if (!cart || !Array.isArray(cart.items)) {
      // No cached cart to render from — fall back to an authoritative render.
      this.needsStructureRender = true;
      return this.reconcileRender();
    }

    const groups = new Map();
    cart.items.forEach((line) => {
      const sig = this.signatureOfLine(line);
      const g = groups.get(sig) || { qty: 0, final: 0, original: 0 };
      g.qty += line.quantity;
      g.final += line.final_line_price;
      g.original += line.original_line_price;
      groups.set(sig, g);
    });

    // Safety: if the cart gained a group that has no card (unexpected for a
    // qty/remove, e.g. a discount auto-added a product), the card set changed —
    // fall back to a full Liquid render so the new card is shown.
    const cardSigs = new Set(
      Array.from(this.sidecart.querySelectorAll('[data-sidecart-item]')).map((c) => c.dataset.propertiesSignature)
    );
    for (const sig of groups.keys()) {
      if (!cardSigs.has(sig)) {
        this.needsStructureRender = true;
        return this.reconcileRender();
      }
    }

    this.sidecart.querySelectorAll('[data-sidecart-item]').forEach((card) => {
      const g = groups.get(card.dataset.propertiesSignature);
      if (!g) {
        card.remove();
        return;
      }
      // Re-show if a card was optimistically hidden by a remove that the server
      // ultimately kept (its group still exists).
      card.style.display = '';
      card.removeAttribute('aria-hidden');
      const input = card.querySelector('[data-quantity]');
      if (input) {
        input.value = g.qty;
        input.defaultValue = String(g.qty);
      }
      this.renderCardPrice(card, g.qty, g.final, g.original);
    });

    this.cacheRefs();
    this.applyCartTotals(cart);
    this.applyUpsellVisibility(cart.items.map((i) => String(i.product_id)));
    this.surfaceClamps();
    this.markContentBusy(false);

    if (this.dirty) {
      this.dirty = false;
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart, fromSidecart: true } }));
    }
  }

  // Update one merged card's price display. Mirrors the price logic in
  // snippets/sidecart-item.liquid exactly, toggling the pre-rendered stable
  // markup rather than rebuilding it.
  renderCardPrice(card, qty, final, original) {
    const compareAtUnit = parseInt(card.dataset.compareAtUnit || '0', 10);
    let hasCompare = false;
    let compare = 0;
    if (original > final) {
      hasCompare = true;
      compare = original;
    } else if (compareAtUnit > 0 && compareAtUnit * qty > final) {
      hasCompare = true;
      compare = compareAtUnit * qty;
    }

    // Keep the per-unit prices fresh so the next optimistic estimate is accurate.
    if (qty > 0) {
      card.dataset.unitPrice = Math.round(final / qty);
      card.dataset.originalUnit = Math.round(original / qty);
    }

    const currentEl = card.querySelector('[data-price]');
    const priceAmount = card.querySelector('[data-price-amount]');
    const saleLabel = card.querySelector('[data-sale-label]');
    const compareEl = card.querySelector('[data-compare-price]');
    const compareAmount = card.querySelector('[data-compare-amount]');

    if (priceAmount) priceAmount.textContent = this.formatMoney(final);
    if (currentEl) currentEl.classList.toggle('sidecart-item__current-price--sale', hasCompare);
    if (saleLabel) saleLabel.hidden = !hasCompare;
    if (compareEl) compareEl.hidden = !hasCompare;
    if (hasCompare && compareAmount) compareAmount.textContent = this.formatMoney(compare);
  }

  // Count badge only (header + any [data-cart-count] outside the drawer). These
  // survive the section innerHTML replace, so they're safe to update early.
  applyCartCount(cart) {
    const count = cart.item_count || 0;
    if (this.countElement) this.countElement.textContent = count;
    this.updateItemsLabel(count);
    document.querySelectorAll('[data-cart-count]').forEach((el) => {
      el.textContent = count;
      el.style.display = count > 0 ? '' : 'none';
    });
  }

  applyCartTotals(cart) {
    this.applyCartCount(cart);
    if (typeof cart.total_price === 'number') {
      this.subtotalCents = cart.total_price; // authoritative; resets optimistic drift
      if (this.subtotalElement) this.subtotalElement.textContent = this.formatMoney(cart.total_price);
      this.updateShippingBar(cart.total_price);
    }
    if ((cart.item_count || 0) === 0) {
      this.showEmptyState();
    } else {
      this.hideEmptyState();
    }
  }

  adjustCountBadge(diff) {
    if (!diff) return;
    const current = parseInt(this.countElement?.textContent || '0', 10);
    const next = Math.max(0, current + diff);
    if (this.countElement) this.countElement.textContent = next;
    this.updateItemsLabel(next);
    document.querySelectorAll('[data-cart-count]').forEach((el) => {
      el.textContent = next;
      el.style.display = next > 0 ? '' : 'none';
    });
    if (next === 0) this.showEmptyState();
  }

  markContentBusy(isBusy) {
    this.sidecart.classList.toggle('is-loading', !!isBusy);
  }

  updateShippingBar(cartTotalCents) {
    if (!this.shippingBarEnabled || !this.shippingBarText || !this.shippingBarFill) return;

    const threshold = this.shippingThreshold;
    const remaining = Math.max(0, threshold - cartTotalCents);
    const progress = threshold > 0 ? Math.min(100, (cartTotalCents / threshold) * 100) : 0;

    this.shippingBarFill.style.width = progress + '%';

    if (remaining <= 0) {
      this.shippingBarText.textContent = this.shippingSuccessMsg;
    } else {
      this.shippingBarText.textContent = this.shippingProgressMsg.replace('[amount]', this.formatMoney(remaining));
    }
  }

  showEmptyState() {
    this.cacheRefs();
    if (this.itemsContainer) this.itemsContainer.classList.add('sidecart__items--hidden');
    if (this.emptyElement) this.emptyElement.classList.remove('sidecart__empty--hidden');
    if (this.footer) this.footer.classList.add('sidecart__footer--hidden');
    if (this.shippingBar) this.shippingBar.classList.add('sidecart__shipping-bar--hidden');
    const upsellRegion = this.sidecart.querySelector('[data-sidecart-upsell]');
    if (upsellRegion) upsellRegion.hidden = true;
  }

  hideEmptyState() {
    this.cacheRefs();
    if (this.itemsContainer) this.itemsContainer.classList.remove('sidecart__items--hidden');
    if (this.emptyElement) this.emptyElement.classList.add('sidecart__empty--hidden');
    if (this.footer) this.footer.classList.remove('sidecart__footer--hidden');
    if (this.shippingBar) this.shippingBar.classList.remove('sidecart__shipping-bar--hidden');
  }

  updateItemsLabel(count) {
    if (this.itemsLabelElement) {
      this.itemsLabelElement.textContent = count === 1 ? this.itemSingular : this.itemPlural;
    }
  }

  // ---- Cart event listeners ----------------------------------------------
  initCartListeners() {
    document.addEventListener('cart:open', () => this.open());
    document.addEventListener('cart:updated', (e) => {
      // Ignore the events we dispatch ourselves; reconcile for external ones
      // (e.g. the product-bundle add path), which may add a card -> full render.
      if (e.detail && e.detail.fromSidecart) return;
      this.requestStructureRender();
      this.enqueue(async () => {});
    });
    this.updateUpsell();
  }

  // ---- Upsell visibility --------------------------------------------------
  applyUpsellVisibility(productIds) {
    const region = this.sidecart.querySelector('[data-sidecart-upsell]');
    if (!region) return;

    if (productIds.length === 0) {
      region.hidden = true;
      return;
    }

    const excludeIds = (region.dataset.excludeIds || '')
      .split(',')
      .map((s) => s.trim())
      .filter(Boolean);

    const allExcluded = excludeIds.length > 0 && productIds.every((id) => excludeIds.includes(id));
    if (allExcluded) {
      region.hidden = true;
      return;
    }

    let anyVisible = false;
    region.querySelectorAll('[data-sidecart-upsell-offer]').forEach((offer) => {
      const inCart = productIds.includes(String(offer.dataset.productId));
      offer.hidden = inCart;
      if (!inCart) anyVisible = true;
    });

    region.hidden = !anyVisible;
  }

  // Instant: reads the cart line cards already in the drawer DOM (ignores cards
  // optimistically removed). Final truth comes from reconcileRender.
  updateUpsellFromDOM() {
    const items = this.sidecart.querySelectorAll('[data-sidecart-item]:not([aria-hidden="true"])');
    const productIds = Array.from(items)
      .map((el) => String(el.dataset.productId))
      .filter((id) => id && id !== 'undefined');
    this.applyUpsellVisibility(productIds);
  }

  // Authoritative: reconciles upsell visibility against the live cart.
  async updateUpsell() {
    if (!this.sidecart.querySelector('[data-sidecart-upsell]')) return;
    let cart;
    try {
      cart = await this.fetchCart();
    } catch (e) {
      return;
    }
    this.applyUpsellVisibility((cart.items || []).map((i) => String(i.product_id)));
  }

  // ---- Add to cart (routed through the same serialized chain) -------------
  handleAddSubmit(form) {
    const submitBtn = form.querySelector('[type="submit"], button[name="add"]');
    const originalDisabled = submitBtn ? submitBtn.disabled : false;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.add('is-loading');
    }

    this.open();

    // For an in-drawer upsell add, drop the item in optimistically so it shows
    // instantly instead of after the add + section-render round-trip. Other adds
    // (e.g. from a product page) keep the loading state while the drawer renders.
    const offer = form.closest('[data-sidecart-upsell-offer]');
    const pending = offer ? this.insertPendingUpsellCard(offer) : null;
    if (!pending) this.markContentBusy(true);

    const fd = new FormData(form);
    const body = new URLSearchParams();
    const id = fd.get('id');
    if (id) body.append('id', id);
    body.append('quantity', fd.get('quantity') || '1');
    const sellingPlan = fd.get('selling_plan');
    if (sellingPlan) body.append('selling_plan', sellingPlan);
    for (const [k, v] of fd.entries()) {
      if (k.indexOf('properties[') === 0) body.append(k, v);
    }

    return this.addToCart(body)
      .catch((err) => {
        this.showToast((err && err.message) || 'Could not add item to cart. Please try again.');
      })
      .finally(() => {
        if (submitBtn) {
          submitBtn.disabled = originalDisabled || false;
          submitBtn.classList.remove('is-loading');
        }
      });
  }

  // Optimistically drop an upsell offer into the cart list so it appears
  // instantly. Clones an existing card for exact markup (SVG controls, classes,
  // translated remove label), then swaps in the offer's image/title/price. The
  // authoritative reconcile (reconcileRender) replaces it a moment later.
  // Returns the inserted card, or null if it couldn't build one (caller then
  // falls back to the loading spinner).
  insertPendingUpsellCard(offer) {
    const container = this.itemsContainer;
    const template = this.sidecart.querySelector('[data-sidecart-item]:not([aria-hidden="true"])');
    if (!container || !template) return null;

    const form = offer.querySelector('form');
    const variantInput = form && form.querySelector('input[name="id"]');
    const variantId = variantInput && variantInput.value;
    if (!variantId) return null;

    const title = (offer.querySelector('.sidecart-upsell__title')?.textContent || '').trim();
    const currentCents = this.parseMoney(offer.querySelector('.sidecart-upsell__current')?.textContent);
    const compareEl = offer.querySelector('.sidecart-upsell__compare');
    const compareCents = compareEl ? this.parseMoney(compareEl.textContent) : 0;
    if (!currentCents) return null;
    const originalCents = compareCents > currentCents ? compareCents : currentCents;

    const card = template.cloneNode(true);
    card.dataset.productId = offer.dataset.productId || '';
    card.dataset.variantId = String(variantId);
    card.dataset.propertiesSignature = String(variantId);
    card.dataset.lineCount = '1';
    card.dataset.inventory = '99999';
    card.dataset.inventoryPolicy = 'deny';
    card.dataset.compareAtUnit = '0';
    card.dataset.unitPrice = String(currentCents);
    card.dataset.originalUnit = String(originalCents);
    card.removeAttribute('aria-hidden');
    card.style.display = '';

    // Swap the image in. Reuse the template card's existing <img> when present
    // so the optimistic image inherits the exact sizing markup of a real card
    // (width/height attributes + object-fit) instead of rendering at the offer
    // thumbnail's natural size. Build one with matching dimensions otherwise.
    const imgLink = card.querySelector('.sidecart-item__image-link');
    const offerImg = offer.querySelector('.sidecart-upsell__image');
    if (imgLink && offerImg) {
      imgLink.removeAttribute('href');
      // Match the real card's image background (product_card_background metafield).
      imgLink.style.backgroundColor = offer.dataset.cardBg || '#FCF0D2';
      let img = imgLink.querySelector('img');
      if (!img) {
        imgLink.innerHTML = '';
        img = document.createElement('img');
        img.loading = 'lazy';
        img.setAttribute('width', '150');
        img.setAttribute('height', '194');
        imgLink.appendChild(img);
      }
      img.className = 'sidecart-item__image';
      // Request the cart-card resolution (the offer src is sized for a thumbnail)
      // and drop the offer's srcset so it doesn't override the chosen src.
      const offerSrc = offerImg.getAttribute('src') || '';
      img.removeAttribute('srcset');
      img.removeAttribute('sizes');
      img.src = offerSrc.replace(/([?&]width=)\d+/, (_m, p) => p + '400');
      img.alt = title;
    }

    const titleEl = card.querySelector('.sidecart-item__title');
    if (titleEl) titleEl.textContent = title;
    ['.sidecart-item__variant', '.sidecart-item__bundle-list', '.sidecart-item__properties', '.sidecart-item__bundle-bottles']
      .forEach((sel) => { const el = card.querySelector(sel); if (el) el.remove(); });

    const input = card.querySelector('[data-quantity]');
    if (input) { input.value = 1; input.defaultValue = '1'; }

    const warn = card.querySelector('[data-stock-warning]');
    if (warn) { warn.hidden = true; warn.textContent = ''; }

    this.renderCardPrice(card, 1, currentCents, originalCents);

    // Insert at the TOP: Shopify returns a newly added (discounted) line first
    // in cart.items, so the authoritative reconcile renders it at the top. We
    // place the optimistic card there too so it doesn't visibly jump.
    container.prepend(card);
    this.hideEmptyState();
    this.adjustCountBadge(1);
    this.adjustSubtotalOptimistic(currentCents);
    this.updateUpsellFromDOM();
    return card;
  }

  addToCart(body) {
    // An add introduces a new card -> needs the Liquid section re-render.
    this.requestStructureRender();
    return this.enqueue(async () => {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', Accept: 'application/json' },
        body
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.description || data.message || 'Could not add item to cart');
      }
      this.dirty = true;
    });
  }

  // ---- Open / close -------------------------------------------------------
  open(trigger = null) {
    this.triggerElement = trigger || document.activeElement;
    this.sidecart.classList.add('is-open');
    this.sidecart.setAttribute('aria-hidden', 'false');
    document.getElementById('cart-toggle')?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    // Reconcile against the server whenever the drawer opens so a stale/ghost
    // line can never be shown (full render: the card set may have changed).
    this.requestStructureRender();
    this.enqueue(async () => {});
    setTimeout(() => this.closeButton?.focus(), 100);
  }

  close() {
    this.sidecart.classList.remove('is-open');
    this.sidecart.setAttribute('aria-hidden', 'true');
    document.getElementById('cart-toggle')?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    this.triggerElement?.focus();
  }

  handleKeydown(e) {
    if (!this.sidecart.classList.contains('is-open')) return;
    if (e.key === 'Escape') {
      this.close();
      return;
    }
    if (e.key === 'Tab') {
      this.handleTabTrap(e);
    }
  }

  handleTabTrap(e) {
    const focusableElements = this.drawer.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    if (focusableElements.length === 0) return;

    const firstElement = focusableElements[0];
    const lastElement = focusableElements[focusableElements.length - 1];

    if (e.shiftKey && document.activeElement === firstElement) {
      e.preventDefault();
      lastElement.focus();
    } else if (!e.shiftKey && document.activeElement === lastElement) {
      e.preventDefault();
      firstElement.focus();
    }
  }

  // ---- Stock warning + toast ---------------------------------------------
  showStockWarning(itemEl, actualQty) {
    const warning = itemEl?.querySelector('[data-stock-warning]');
    if (!warning) return;

    const msg = this.sidecart.dataset.stockWarning || 'Only COUNT available';
    warning.textContent = msg.replace('COUNT', actualQty);
    warning.hidden = false;

    if (this.stockWarningTimeouts.has(itemEl)) {
      clearTimeout(this.stockWarningTimeouts.get(itemEl));
    }
    const timeout = setTimeout(() => {
      warning.hidden = true;
      this.stockWarningTimeouts.delete(itemEl);
    }, 8000);
    this.stockWarningTimeouts.set(itemEl, timeout);
  }

  showToast(msg) {
    const toast = document.createElement('div');
    toast.className = 'sidecart__toast';
    toast.textContent = msg;
    this.drawer?.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('sidecart__toast--visible'));
    setTimeout(() => {
      toast.classList.remove('sidecart__toast--visible');
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  formatMoney(cents) {
    const b = '{' + '{';
    const e = '}' + '}';
    const moneyFormat = this.sidecart?.dataset.moneyFormat || ('$' + b + 'amount' + e);
    const amount = (cents / 100).toFixed(2);
    const amountNoDecimals = Math.floor(cents / 100).toString();
    const amountWithCommas = amount.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    const amountNoDecimalsWithCommas = amountNoDecimals.replace(/\B(?=(\d{3})+(?!\d))/g, ',');

    return moneyFormat
      .replace(b + 'amount_with_comma_separator' + e, amountWithCommas.replace('.', ','))
      .replace(b + 'amount_no_decimals_with_comma_separator' + e, amountNoDecimalsWithCommas.replace(/,/g, '.'))
      .replace(b + 'amount_with_apostrophe_separator' + e, amountWithCommas.replace(/,/g, "'"))
      .replace(b + 'amount_no_decimals' + e, amountNoDecimals)
      .replace(b + 'amount' + e, amount);
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => {
    window.__sidecartInstance = new Sidecart();
  });
} else {
  window.__sidecartInstance = new Sidecart();
}

(function initAjaxAddToCart() {
  function isProductForm(form) {
    if (!form || form.tagName !== 'FORM') return false;
    const action = form.getAttribute('action') || '';
    if (action.includes('/cart/add')) return true;
    if (form.querySelector('input[name="form_type"][value="product"]')) return true;
    return false;
  }

  document.addEventListener('submit', (e) => {
    const form = e.target.tagName === 'FORM' ? e.target : e.target.closest('form');
    if (!isProductForm(form)) return;
    // Forms that explicitly want a full-page redirect opt out of AJAX.
    if (form.querySelector('input[name="return_to"]')) return;

    e.preventDefault();

    const instance = window.__sidecartInstance;
    if (!instance) {
      form.submit();
      return;
    }
    instance.handleAddSubmit(form);
  });
})();

if (Shopify.designMode) {
  document.addEventListener('shopify:section:select', (e) => {
    if (e.target.querySelector('[data-sidecart]')) {
      const sidecart = document.getElementById('sidecart');
      if (sidecart) {
        sidecart.classList.add('is-open');
        sidecart.setAttribute('aria-hidden', 'false');
      }
    }
  });

  document.addEventListener('shopify:section:deselect', (e) => {
    if (e.target.querySelector('[data-sidecart]')) {
      const sidecart = document.getElementById('sidecart');
      if (sidecart) {
        sidecart.classList.remove('is-open');
        sidecart.setAttribute('aria-hidden', 'true');
      }
    }
  });
}
