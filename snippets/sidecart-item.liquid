{% doc %}
  Renders a single MERGED cart row in the sidecart.

  A Buy-X-Get-Y automatic discount splits one variant into several Shopify line
  items (e.g. 2 wipes at full price + 1 wipe at the deal price). To avoid showing
  the same product as two cards, the parent section (sections/sidecart.liquid)
  groups cart.items by variant + line-item properties and renders ONE card per
  group, passing the group totals here. The representative `item` supplies the
  image/title/variant/bundle visuals; quantity and prices come from the group.

  Targeting is done by `data-properties-signature` (+ `data-variant-id`), NOT by
  line item key — keys mutate whenever the discount re-allocates, so the JS
  re-resolves the live line(s) from /cart.js on every mutation.

  @param {line_item} item - Representative (first) line item of the group
  @param {number} group_quantity - Combined quantity across the group's lines
  @param {number} group_final_line_price - Combined charged price (cents)
  @param {number} group_original_line_price - Combined pre-discount price (cents)
  @param {number} group_line_count - How many Shopify lines this card represents
  @param {string} group_signature - variant_id + properties signature (targeting key)
{% enddoc %}

{%- liquid
  assign item_url = item.url
  assign item_image = item.product.metafields.custom.card_image_portrait | default: item.product.metafields.custom.card_image | default: item.image
  assign card_bg = item.product.metafields.custom.product_card_background | default: '#FCF0D2'
  assign item_title = item.product.title
  assign item_variant = item.variant.title
  assign item_quantity = group_quantity | default: item.quantity
  assign item_price = group_final_line_price | default: item.final_line_price
  assign item_original = group_original_line_price | default: item.original_line_price

  assign bundle_titles_str = ''
  assign bundle_handles_str = ''
  for property in item.properties
    assign key_prefix_scent = property.first | slice: 0, 6
    assign key_prefix_handle = property.first | slice: 0, 8
    if key_prefix_scent == 'Scent ' and property.last != blank
      assign bundle_titles_str = bundle_titles_str | append: property.last | append: '||'
    endif
    if key_prefix_handle == '_handle_' and property.last != blank
      assign bundle_handles_str = bundle_handles_str | append: property.last | append: '||'
    endif
  endfor
  assign bundle_scents = bundle_titles_str | split: '||'
  assign bundle_handles = bundle_handles_str | split: '||'
  assign has_bundle_scents = false
  if bundle_scents.size > 0
    assign has_bundle_scents = true
  endif

  assign has_compare_price = false
  assign compare_price = 0
  if item_original > item_price
    assign has_compare_price = true
    assign compare_price = item_original
  elsif item.variant.compare_at_price > item.variant.price
    assign has_compare_price = true
    assign compare_price = item.variant.compare_at_price | times: item_quantity
  endif
-%}

<li class="sidecart-item" data-sidecart-item data-product-id="{{ item.product.id }}" data-variant-id="{{ item.variant_id }}" data-properties-signature="{{ group_signature | escape }}" data-line-count="{{ group_line_count | default: 1 }}" data-inventory="{{ item.variant.inventory_quantity | default: 99999 }}" data-inventory-policy="{{ item.variant.inventory_policy }}" data-compare-at-unit="{{ item.variant.compare_at_price | default: 0 }}">
  <a href="{{ item_url }}" class="sidecart-item__image-link" style="background-color: {{ card_bg }};">
    {%- if has_bundle_scents and bundle_handles.size > 0 -%}
      <div class="sidecart-item__bundle-bottles">
        {%- for handle in bundle_handles -%}
          {%- assign scent_product = all_products[handle] -%}
          {%- if scent_product != blank -%}
            {%- assign bottle_image = scent_product.metafields.custom.card_image | default: scent_product.featured_image -%}
            {%- if bottle_image -%}
              <img
                src="{{ bottle_image | image_url: width: 1200 }}"
                srcset="{{ bottle_image | image_url: width: 400 }} 400w, {{ bottle_image | image_url: width: 800 }} 800w, {{ bottle_image | image_url: width: 1200 }} 1200w"
                sizes="120px"
                loading="lazy"
                class="sidecart-item__bundle-bottle"
                alt="{{ scent_product.title | escape }}">
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- elsif item_image -%}
      {{ item_image | image_url: width: 400 | image_tag:
        loading: 'lazy',
        class: 'sidecart-item__image',
        alt: item_title,
        width: 150,
        height: 194
      }}
    {%- else -%}
      <div class="sidecart-item__placeholder">
        {{ 'product-1' | placeholder_svg_tag: 'sidecart-item__placeholder-svg' }}
      </div>
    {%- endif -%}
  </a>

  <div class="sidecart-item__details">
    <div class="sidecart-item__info">
      <h3 class="sidecart-item__title">
        <a href="{{ item_url }}">{{ item_title }}</a>
      </h3>
      {%- if item_variant != 'Default Title' -%}
        <p class="sidecart-item__variant">{{ item_variant }}</p>
      {%- endif -%}
      {%- if has_bundle_scents -%}
        <ul class="sidecart-item__bundle-list">
          {%- for scent_title in bundle_scents -%}
            <li class="sidecart-item__bundle-scent">{{ scent_title }}</li>
          {%- endfor -%}
        </ul>
      {%- elsif item.properties.size > 0 -%}
        <ul class="sidecart-item__properties">
          {%- for property in item.properties -%}
            {%- unless property.last == blank or property.first contains '_' -%}
              <li class="sidecart-item__property">{{ property.first }}: {{ property.last }}</li>
            {%- endunless -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="sidecart-item__controls">
      <p class="sidecart-item__stock-warning" data-stock-warning role="status" aria-live="polite" hidden></p>
      <div class="sidecart-item__quantity">
        <button
          type="button"
          class="sidecart-item__qty-btn"
          aria-label="{{ 'sidecart.decrease_quantity' | t }}"
          data-action="decrease">
          <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <input
          type="number"
          class="sidecart-item__qty-input"
          data-quantity
          value="{{ item_quantity }}"
          min="0"
          aria-label="{{ 'sidecart.quantity' | t }}">
        <button
          type="button"
          class="sidecart-item__qty-btn"
          aria-label="{{ 'sidecart.increase_quantity' | t }}"
          data-action="increase">
          <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="sidecart-item__price">
        {%- comment -%} Stable structure: JS updates the amount spans / toggles in place on qty change (see renderCardPrice). {%- endcomment -%}
        <s class="sidecart-item__compare-price" data-compare-price{% unless has_compare_price %} hidden{% endunless %}>
          <span class="visually-hidden">{{ 'products.regular_price' | t }}:</span>
          <span data-compare-amount>{{ compare_price | money }}</span>
        </s>
        <span class="sidecart-item__current-price{% if has_compare_price %} sidecart-item__current-price--sale{% endif %}" data-price>
          <span class="visually-hidden" data-sale-label{% unless has_compare_price %} hidden{% endunless %}>{{ 'products.sale_price' | t }}:</span>
          <span data-price-amount>{{ item_price | money }}</span>
        </span>
      </div>
    </div>

    <button
      type="button"
      class="sidecart-item__remove"
      data-action="remove"
      aria-label="{{ 'sidecart.remove_item' | t }}: {{ item_title }}">
      {{ 'sidecart.remove_item' | t }}
    </button>
  </div>
</li>
