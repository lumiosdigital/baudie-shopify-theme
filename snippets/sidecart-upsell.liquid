{% doc %}
  Renders the sidecart upsell region. The region is rendered once on full page
  load (where section settings resolve reliably) and lives OUTSIDE the
  AJAX-replaced content/footer regions, so it is never wiped on cart updates.

  Visibility is driven by JavaScript (see `updateUpsell` in sidecart.liquid),
  using the live cart from `/cart.js`:
  - hidden when the cart is empty or contains only excluded ("wipes") products
  - each offer is hidden when its product is already in the cart

  Available offers are rendered as cards; the exclusion collection's product ids
  are exposed via `data-exclude-ids` for the JS check.

  @param {boolean} enabled - Whether the upsell feature is turned on
  @param {string} heading - Heading text shown above the offers
  @param {product} [product_1] - First upsell product
  @param {product} [product_2] - Second upsell product
  @param {collection} [exclude_collection] - Cart of only these products shows no upsell
{% enddoc %}

{%- liquid
  assign variant_1 = product_1.selected_or_first_available_variant
  assign variant_2 = product_2.selected_or_first_available_variant

  comment
    Don't upsell a product that's tagged "coming soon" (matches the storefront
    coming-soon state), even if it still has stock.
  endcomment
  assign cs_1 = false
  if product_1.tags contains 'coming-soon' or product_1.tags contains 'Coming soon' or product_1.tags contains 'coming soon' or product_1.tags contains 'Coming Soon'
    assign cs_1 = true
  endif
  assign cs_2 = false
  if product_2.tags contains 'coming-soon' or product_2.tags contains 'Coming soon' or product_2.tags contains 'coming soon' or product_2.tags contains 'Coming Soon'
    assign cs_2 = true
  endif

  assign has_1 = false
  if product_1 != blank and variant_1 != blank and variant_1.available and cs_1 == false
    assign has_1 = true
  endif

  assign has_2 = false
  if product_2 != blank and variant_2 != blank and variant_2.available and cs_2 == false
    assign has_2 = true
  endif

  assign render_region = false
  if enabled and has_1 or enabled and has_2
    assign render_region = true
  endif
-%}

{%- if render_region -%}
  <div
    class="sidecart-upsell"
    data-sidecart-upsell
    hidden
    data-exclude-ids="{% if exclude_collection != blank %}{% for p in exclude_collection.products %}{{ p.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}">
    {%- if heading != blank -%}
      <p class="sidecart-upsell__heading">{{ heading }}</p>
    {%- endif -%}
    <ul class="sidecart-upsell__list" role="list">
      {%- if has_1 -%}
        {% render 'sidecart-upsell-item', product: product_1 %}
      {%- endif -%}
      {%- if has_2 -%}
        {% render 'sidecart-upsell-item', product: product_2 %}
      {%- endif -%}
    </ul>
  </div>
{%- endif -%}
